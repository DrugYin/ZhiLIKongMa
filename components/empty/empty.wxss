/* components/empty/empty.wxss */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-container.hidden {
  display: none;
}

.empty-icon {
  margin-bottom: 24rpx;
}

.empty-icon.size-small .empty-image {
  width: 120rpx;
  height: 120rpx;
}

.empty-icon.size-medium .empty-image {
  width: 160rpx;
  height: 160rpx;
}

.empty-icon.size-large .empty-image {
  width: 200rpx;
  height: 200rpx;
}

.empty-image {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  border-radius: 50%;
}

.icon-text {
  font-size: 60rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.empty-description {
  font-size: 28rpx;
  color: #999999;
  line-height: 1.5;
  margin-bottom: 32rpx;
  max-width: 400rpx;
}

.empty-button {
  width: 100%;
  display: flex;
  justify-content: center;
}

.empty-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  color: #ffffff;
  background-color: #007aff;
  border-radius: 8rpx;
  border: none;
  line-height: 1.5;
}

.empty-btn::after {
  border: none;
}

.empty-btn:active {
  opacity: 0.8;
}
