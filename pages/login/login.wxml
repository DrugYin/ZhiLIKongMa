<!--pages/login/login.wxml-->
<t-toast id="t-toast" />
<view class="container">
  <view class="header">
    <custom-navbar title="智力控码" titleClass="nav-title" showBack="{{true}}" bind:go-back="handleGoBack"/>
  </view>
  <view class="content">
    <view wx:if="{{ !isFirstLogin }}" class="login-card">
      <view class="login-card-tab">
        <t-tabs class="bigger" bottom-line-mode="full" defaultValue="{{false}}" bind:change="onTabsChange">
          <t-tab-panel label="学生登录" value="{{false}}" />
          <t-tab-panel label="教师登录" value="{{true}}" />
        </t-tabs>
        <view wx:if="{{ isTeacherLogin }}" class="teacher-login-form">
          <view wx:if="{{ usePasswordLogin }}">
            <t-input 
              placeholder="请输入账号" 
              value="{{ loginAccount }}"
              bind:change="onInputChange"
              data-field="loginAccount"
            >
              <view slot="label" class="custom-required-label"> 账号 </view>
            </t-input>
            <t-input
              type="password" 
              placeholder="请输入密码"
              value="{{ loginPassword }}"
              bind:change="onInputChange" 
              data-field="loginPassword"
            >
              <view slot="label" class="custom-required-label"> 密码 </view>
            </t-input>
            <button
              bindtap="teacherPasswordLogin"
              class="action-btn primary-btn"
            > 
              登录
            </button>
          </view>
          <view wx:else style="width: 70%;">
            <button
              bindtap="teacherLogin"
              class="action-btn wechat-btn"
            >
              微信一键登录
            </button>
          </view>
          <text class="switch-login-mode" bind:tap="handleChangeLoginType">{{ usePasswordLogin ? '使用微信一键登录' : '使用账号密码登录'}}</text>
        </view>
        <view wx:else class="student-login-form">
          <view style="width: 70%;">
            <button
              bindtap="studentLogin"
              class="action-btn wechat-btn"
            >
              微信一键登录
            </button>
          </view>
        </view>
      </view>
    </view>
    <view wx:else class="first-login-card">
      <view wx:if="{{ isTeacherLogin }}" class="teacher-register-form">
        <button class="avatar-wrapper" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar" data-field="teacherInfo.avatarUrl">
          <image class="avatar" src="{{teacherInfo.avatarUrl || defaultAvatarUrl}}" mode="aspectFill" />
        </button>
        <t-input placeholder="请输入真实姓名" value="{{ teacherInfo.name }}" bind:change="onInputChange" data-field="teacherInfo.name">
          <view slot="label" class="custom-required-label"> 姓名 </view>
        </t-input>
        <t-input
          placeholder="输入手机号码"
          value="{{ teacherInfo.phone }}"
          type="number"
          tips="{{ phoneError ? '手机号输入不正确' : ''}}"
          bindchange="onPhoneInput"
          data-field="teacherInfo.phone"
        >
          <view slot="label" class="custom-required-label"> 电话 </view>
        </t-input>
        <t-cell title="项目" arrow required hover note="{{ teacherInfo.project || '请选择' }}" bind:click="onProjectPicker" />
        <t-picker
          visible="{{ projectPickerVisible }}"
          value="{{ teacherInfo.project }}"
          data-key="teacherInfo.project"
          title="选择项目"
          cancelBtn="取消"
          confirmBtn="确定"
          usingCustomNavbar
          bindcancel="onPickerCancel"
          bindpick="onColumnChange"
          bindchange="onPickerChange"
        >
          <t-picker-item options="{{ projects }}" />
        </t-picker>
        <t-button style="width: 60%" theme="primary" size="large" shape="round" bind:tap="teacherRegister" >提交并绑定微信</t-button>
      </view>
      <view wx:else 
      class="student-register-form">
        <button class="avatar-wrapper" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar" data-field="userInfo.avatarUrl">
          <image class="avatar" src="{{userInfo.avatarUrl || defaultAvatarUrl}}" mode="aspectFill" />
        </button>
        <t-input placeholder="请输入真实姓名" value="{{ userInfo.userName }}" bind:change="onInputChange" data-field="userInfo.userName">
          <view slot="label" class="custom-required-label"> 姓名 </view>
        </t-input>
        <t-input placeholder="请输入学校" value="{{ userInfo.school }}" bind:change="onInputChange" data-field="userInfo.school">
          <view slot="label" class="custom-required-label"> 学校 </view>
        </t-input>
        <t-cell title="年级" arrow required hover note="{{ userInfo.grade || '请选择' }}" bind:click="onGradePicker" />
        <t-picker
          visible="{{ gradePickerVisible }}"
          value="{{ userInfo.grade }}"
          data-key="userInfo.grade"
          title="选择年级"
          cancelBtn="取消"
          confirmBtn="确定"
          usingCustomNavbar
          bindcancel="onPickerCancel"
          bindpick="onColumnChange"
          bindchange="onPickerChange"
        >
          <t-picker-item options="{{ grades }}" />
        </t-picker>
        <t-input
          placeholder="输入手机号码"
          value="{{ userInfo.phone }}"
          type="number"
          tips="{{ phoneError ? '手机号输入不正确' : ''}}"
          bindchange="onPhoneInput"
          data-field="userInfo.phone"
        >
          <view slot="label" class="custom-required-label"> 电话 </view>
        </t-input>
        <t-input label="地址" placeholder="请输入地址" value="{{ userInfo.address }}" bind:change="onInputChange" data-field="userInfo.address"/>
        <t-button style="width: 60%" theme="primary" size="large" shape="round" bind:tap="studentRegister" >注册</t-button>
      </view>
    </view>
  </view>

</view>
