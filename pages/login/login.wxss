/* pages/login/login.wxss */

.content {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 0;
  overflow-y: auto;
  overflow-x: hidden;
}

.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px;
}

.logo {
  width: 160px;
  height: 160px;
  border-radius: 50%;
  margin-bottom: 20px;
}

.app-name {
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 10px;
}

.login-desc {
  font-size: 14px;
  margin-bottom: 40px;
}

.login-btn {
  width: 80%;
  max-width: 300px;
  border-radius: 8px;
  color: #fff;
  font-size: 16px;
  margin-bottom: 20px;
}

.skip-btn {
  font-size: 14px;
  margin-bottom: 30px;
  padding: 8px 16px;
}

.agreement {
  margin-top: 30px;
  font-size: 12px;
}

.link {
  color: #007aff;
}

.register-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 20px;
  overflow-x: hidden;
  touch-action: pan-y;
  background-color: #fff;
  border-radius: 20px;
}

/* 头像 */
.avatar-wrapper {
  padding: 0;
  width: 80px !important;
  border-radius: 8px;
  margin-bottom: 40px;
}

.avatar {
  display: block;
  width: 80px;
  height: 80px;
}

.custom-required-label::after {
  content: '*';
  color: red;
  font-size: 32rpx;
  margin-left: 4rpx;
}

.register-btn {
  width: 60%;
  margin-top: 20rpx;
}
