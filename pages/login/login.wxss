/* pages/login/login.wxss */

.content {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow-y: auto;
  overflow-x: hidden;
}

.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px;
}

.logo {
  width: 160px;
  height: 160px;
  border-radius: 50%;
  margin-bottom: 20px;
}

.app-name {
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 10px;
}

.login-desc {
  font-size: 14px;
  margin-bottom: 40px;
}

.login-btn {
  width: 80%;
  max-width: 300px;
  border-radius: 8px;
  color: #fff;
  font-size: 16px;
  margin-bottom: 20px;
}

.skip-btn {
  font-size: 14px;
  margin-bottom: 30px;
  padding: 8px 16px;
}

.agreement {
  margin-top: 30px;
  font-size: 12px;
}

.link {
  color: #007aff;
}

.action-wrapper {
  margin-top: 20rpx;
  margin-left: auto;
  margin-right: auto;
  text-align: center;
}

.register-btn {
  width: 60%;
}

