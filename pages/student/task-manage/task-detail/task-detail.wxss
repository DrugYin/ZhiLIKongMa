.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f7f8fa 0%, #eef2f7 100%);
}

.header {
  position: relative;
  z-index: 20;
  background-color: rgba(255, 255, 255, 0.96);
}

.content {
  box-sizing: border-box;
  height: calc(100vh - 96rpx);
  padding: 0rpx 24rpx calc(50rpx + env(safe-area-inset-top));
}

.hero-card,
.section-card,
.state-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(103, 126, 167, 0.08);
  box-shadow: 0 20rpx 50rpx rgba(24, 62, 107, 0.08);
}

.section-card:nth-last-child(2) {
  margin-bottom: 50rpx;
}

.hero-card {
  background: linear-gradient(135deg, #ffffff 0%, #eef6ff 52%, #f5fbff 100%);
}

.hero-title-row,
.summary-grid,
.section-head {
  display: flex;
}

.hero-title-row,
.section-head {
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-title-group {
  flex: 1;
  min-width: 0;
}

.hero-title,
.section-title,
.state-title {
  color: #16324c;
  font-weight: 700;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  line-height: 1.4;
  word-break: break-all;
}

.section-title,
.state-title {
  font-size: 30rpx;
}

.hero-subtitle,
.state-desc {
  display: block;
  margin-top: 12rpx;
  color: #6a7d90;
  font-size: 24rpx;
  line-height: 1.8;
}

.hero-desc,
.detail-desc {
  display: block;
  color: #35536c;
  font-size: 26rpx;
  font-weight: 500;
  line-height: 1.8;
}

.hero-desc {
  margin-top: 22rpx;
}

.section-subtitle {
  max-width: 280rpx;
  color: #7a8797;
  font-size: 22rpx;
  line-height: 1.7;
  text-align: right;
}

.section-tip {
  display: block;
  margin-top: 14rpx;
  color: #7a8797;
  font-size: 22rpx;
  line-height: 1.7;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.plain-tag {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #1f4f78;
  background: rgba(31, 122, 224, 0.1);
}

.plain-tag-light {
  color: #51697f;
  background: #eef3f8;
}

.ghost-copy-btn {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  margin: 0;
  border-radius: 999rpx;
  color: #1f4f78;
  background: #e7f1fb;
  font-size: 24rpx;
  font-weight: 600;
}

.ghost-copy-btn::after {
  border: none;
}

.summary-grid {
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 22rpx;
}

.summary-item {
  width: calc(50% - 10rpx);
  margin-bottom: 18rpx;
  box-sizing: border-box;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f6f9fc;
}

.summary-label {
  display: block;
  color: #7b8798;
  font-size: 22rpx;
}

.summary-value {
  display: block;
  margin-top: 10rpx;
  color: #1f3349;
  font-size: 26rpx;
  line-height: 1.6;
  word-break: break-all;
}

.detail-panel {
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(31, 122, 224, 0.08);
}

.detail-panel-soft {
  background: #f6f9fc;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 18rpx;
}

.task-image {
  width: 100%;
  height: 240rpx;
  border-radius: 22rpx;
  background: #eef3f8;
}

.file-list {
  margin-top: 18rpx;
}

.file-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 16rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 2rpx solid #e5e7eb;
}

.file-main {
  flex: 1;
  min-width: 0;
}

.file-name {
  display: block;
  color: #111827;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.6;
  word-break: break-all;
}

.file-meta {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.7;
}

.file-preview-text {
  flex-shrink: 0;
  color: #1f7ae0;
  font-size: 24rpx;
  font-weight: 600;
}

.state-card {
  text-align: center;
}

.footer-placeholder {
  height: 32rpx;
}
