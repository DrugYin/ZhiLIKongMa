<view class="container">
  <view class="header">
    <custom-navbar title="提交记录" showBack="{{true}}" placeholder="{{true}}" />
  </view>

  <scroll-view class="content" scroll-y enhanced bounces="{{false}}" show-scrollbar="{{false}}">
    <view wx:if="{{loading}}" class="state-card">
      <text class="state-title">提交记录加载中</text>
      <text class="state-desc">正在同步该任务下的提交历史。</text>
    </view>

    <block wx:elif="{{taskInfo}}">
      <view class="hero-card">
        <view class="hero-top">
          <view class="hero-copy">
            <text class="hero-title">{{taskInfo.titleText}}</text>
            <text class="hero-desc">{{taskInfo.projectText}} · {{taskInfo.classText}}</text>
          </view>
          <t-button size="small" theme="primary" bind:tap="goToSubmit">再次提交</t-button>
        </view>
        <text class="hero-tip">任务详情页只展示最近两次提交，这里会继续承接更多提交记录。</text>
      </view>

      <view class="summary-card">
        <view class="summary-grid">
          <view class="summary-item">
            <text class="summary-label">全部提交</text>
            <text class="summary-value">{{stats.total}}</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">待审核</text>
            <text class="summary-value">{{stats.pending}}</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">已通过</text>
            <text class="summary-value">{{stats.approved}}</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">已拒绝</text>
            <text class="summary-value">{{stats.rejected}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{records.length}}" class="record-list">
        <view wx:for="{{records}}" wx:key="_id" class="record-card">
          <view class="record-head">
            <view class="record-copy">
              <text class="record-title">第 {{item.submitNoText}} 次提交</text>
              <text class="record-time">{{item.submitTimeText}}</text>
            </view>
            <text class="status-tag" style="{{item.statusStyle}}">{{item.statusText}}</text>
          </view>

          <view class="record-meta-row">
            <text class="meta-tag">{{item.materialText}}</text>
            <text class="meta-tag">{{item.overtimeText}}</text>
            <text class="meta-tag">评分：{{item.scoreText}}</text>
          </view>

          <text class="record-desc">{{item.descriptionText}}</text>

          <view wx:if="{{item.feedbackText}}" class="feedback-panel">
            <text class="feedback-label">教师反馈</text>
            <text class="feedback-text">{{item.feedbackText}}</text>
          </view>
        </view>
      </view>

      <view wx:else class="state-card">
        <text class="state-title">还没有提交记录</text>
        <text class="state-desc">先去完成一次提交，后续所有历史都会沉淀在这里。</text>
        <button class="ghost-btn" bindtap="goToSubmit">去提交</button>
      </view>

      <button wx:if="{{hasMore}}" class="load-more-btn" bindtap="onLoadMore" loading="{{loadingMore}}">
        {{loadingMore ? '加载中...' : '加载更多记录'}}
      </button>
    </block>

    <view wx:else class="state-card">
      <text class="state-title">当前任务暂不可查看</text>
      <text class="state-desc">可能是任务已下线，或者当前账号没有查看记录的权限。</text>
    </view>

    <view class="footer-placeholder"></view>
  </scroll-view>
</view>
