.container {
  height: 100vh;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  overflow: hidden;
  background: linear-gradient(180deg, #f7f8fa 0%, #eef2f7 100%);
}

.header {
  position: relative;
  flex-shrink: 0;
  z-index: 20;
  background-color: rgba(255, 255, 255, 0.96);
}

.content {
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
}

.hero-card,
.summary-card,
.tab-card,
.task-card,
.state-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(103, 126, 167, 0.08);
  box-shadow: 0 20rpx 50rpx rgba(24, 62, 107, 0.08);
}

.hero-card {
  background: linear-gradient(135deg, #ffffff 0%, #eef6ff 52%, #f5fbff 100%);
}

.hero-top,
.task-top,
.summary-grid,
.meta-grid,
.task-footer,
.tab-header {
  display: flex;
}

.hero-top,
.task-top,
.tab-header {
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-copy,
.task-copy {
  flex: 1;
  min-width: 0;
}

.hero-title,
.task-title,
.state-title,
.tab-title {
  color: #16324c;
  font-weight: 700;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  line-height: 1.4;
  word-break: break-all;
}

.task-title,
.state-title,
.tab-title {
  font-size: 30rpx;
}

.hero-desc,
.state-desc,
.tab-desc,
.time-text {
  display: block;
  color: #6a7d90;
  font-size: 24rpx;
  line-height: 1.8;
}

.hero-desc {
  margin-top: 12rpx;
}

.hero-tag,
.scope-tag,
.plain-tag {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.hero-tag {
  color: #1f4f78;
  background: rgba(31, 122, 224, 0.1);
}

.summary-grid,
.meta-grid {
  flex-wrap: wrap;
  justify-content: space-between;
}

.summary-item,
.meta-item {
  width: calc(50% - 10rpx);
  margin-bottom: 18rpx;
  box-sizing: border-box;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f6f9fc;
}

.summary-item:nth-last-child(-n + 2),
.meta-item:nth-last-child(-n + 2) {
  margin-bottom: 0;
}

.summary-label,
.meta-label {
  display: block;
  color: #7b8798;
  font-size: 22rpx;
}

.summary-value,
.meta-value {
  display: block;
  margin-top: 10rpx;
  color: #1f3349;
  font-size: 30rpx;
  line-height: 1.5;
  word-break: break-all;
}

.tab-desc {
  max-width: 280rpx;
  text-align: right;
  font-size: 22rpx;
}

.task-project {
  display: inline-flex;
  margin-top: 14rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #0f6b66;
  background: rgba(15, 107, 102, 0.1);
}

.scope-tag {
  color: #51697f;
  background: #eef3f8;
}

.scope-tag-active {
  color: #0c7f58;
  background: rgba(12, 127, 88, 0.1);
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.plain-tag {
  color: #1f4f78;
  background: rgba(31, 122, 224, 0.1);
}

.plain-tag-light {
  color: #51697f;
  background: #eef3f8;
}

.meta-grid {
  margin-top: 24rpx;
}

.task-desc {
  display: block;
  margin-top: 22rpx;
  padding: 22rpx 24rpx;
  border-left: 6rpx solid #1f7ae0;
  border-radius: 20rpx;
  background: rgba(31, 122, 224, 0.08);
  color: #35536c;
  font-size: 24rpx;
  line-height: 1.8;
}

.task-footer {
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 24rpx;
}

.detail-link {
  flex-shrink: 0;
  color: #1f7ae0;
  font-size: 24rpx;
  font-weight: 600;
}

.bottom-tab-bar .tab-card {
  margin-bottom: 0;
  box-shadow: 0 16rpx 40rpx rgba(24, 62, 107, 0.12);
}

.primary-btn,
.ghost-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  margin: 0;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.primary-btn::after,
.ghost-btn::after {
  border: none;
}

.primary-btn {
  color: #ffffff;
  background: linear-gradient(135deg, #1f7ae0 0%, #4a8ff5 100%);
}

.ghost-btn {
  color: #1f4f78;
  background: #e7f1fb;
}

.state-card {
  text-align: center;
}

.state-btn {
  margin-top: 24rpx;
}

