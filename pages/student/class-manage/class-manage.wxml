<view class="container">
  <view class="header">
    <custom-navbar title="班级管理" showBack="{{true}}" placeholder="{{true}}" />
  </view>

  <scroll-view class="content" scroll-y enhanced>
    <view class="hero-card">
      <text class="hero-title">加入你的班级</text>
      <text class="hero-desc">支持输入老师提供的邀请码，也支持老师直接分享班级邀请卡片给你。</text>
    </view>

    <view wx:if="{{loading}}" class="state-card">
      <text class="state-title">正在加载班级状态</text>
      <text class="state-desc">请稍候，我们正在同步你的班级与申请记录。</text>
    </view>

    <block wx:elif="{{!isLoggedIn || !isRegistered}}">
      <view class="state-card">
        <text class="state-title">还没有登录</text>
        <text class="state-desc">登录并完成注册后，你就可以通过邀请码申请加入班级。</text>
        <t-button theme="primary" size="large" block bind:tap="goLogin">去登录</t-button>
      </view>
    </block>

    <block wx:elif="{{status === 'joined' && joinedClass}}">
      <view class="section-card">
        <view class="section-header">
          <text class="section-title">当前班级</text>
          <text class="section-tag">已加入</text>
        </view>

        <view class="summary-grid">
          <view class="summary-item">
            <text class="summary-label">班级名称</text>
            <text class="summary-value">{{joinedClass.class_name}}</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">邀请码</text>
            <text class="summary-value">{{joinedClass.class_code}}</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">老师</text>
            <text class="summary-value">{{joinedClass.teacherText}}</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">人数</text>
            <text class="summary-value">{{joinedClass.memberText}}</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">上课时间</text>
            <text class="summary-value">{{joinedClass.classTimeText}}</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">上课地点</text>
            <text class="summary-value">{{joinedClass.locationText}}</text>
          </view>
        </view>

        <view class="detail-panel">
          <text class="detail-title">班级说明</text>
          <text class="detail-desc">{{joinedClass.descriptionText}}</text>
          <text class="detail-meta">加入时间：{{joinedClass.joinTimeText}}</text>
        </view>

        <view class="action-row">
          <button class="ghost-btn" bindtap="onCopyClassCode">复制邀请码</button>
        </view>
      </view>
    </block>

    <block wx:elif="{{status === 'pending' && pendingApplication}}">
      <view class="section-card">
        <view class="section-header">
          <text class="section-title">待审核申请</text>
          <text class="section-tag section-tag-warn">审核中</text>
        </view>

        <view class="summary-grid">
          <view class="summary-item">
            <text class="summary-label">班级名称</text>
            <text class="summary-value">{{pendingApplication.class_name}}</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">邀请码</text>
            <text class="summary-value">{{pendingApplication.class_code}}</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">老师</text>
            <text class="summary-value">{{pendingApplication.teacherText}}</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">人数</text>
            <text class="summary-value">{{pendingApplication.memberText}}</text>
          </view>
        </view>

        <view class="detail-panel">
          <text class="detail-title">申请理由</text>
          <text class="detail-desc">{{pendingApplication.applyReasonText}}</text>
          <text class="detail-meta">提交时间：{{pendingApplication.createTimeText}}</text>
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="section-card">
        <view class="section-header">
          <text class="section-title">输入邀请码</text>
          <text class="section-tag section-tag-free">未加入</text>
        </view>
        <text class="section-desc">请输入老师提供的邀请码，查看班级信息后再确认申请。</text>

        <view class="form-panel">
          <t-input
            label="邀请码"
            placeholder="例如：AB12CD"
            maxlength="12"
            value="{{inviteCode}}"
            clearable
            bind:change="onInviteCodeChange"
          />
        </view>

        <t-button theme="primary" size="large" block bind:tap="goToJoinConfirm">查看班级并申请加入</t-button>
      </view>

      <view class="tips-card">
        <text class="tips-title">加入方式说明</text>
        <text class="tips-item">1. 可向老师索取邀请码，在本页输入后继续申请。</text>
        <text class="tips-item">2. 老师直接分享班级邀请卡片时，你也可以从卡片直接进入申请页。</text>
        <text class="tips-item">3. 提交申请后，需要等待老师审核通过才能正式加入班级。</text>
      </view>
    </block>

    <view class="footer-placeholder"></view>
  </scroll-view>
</view>
