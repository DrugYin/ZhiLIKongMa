.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f7f8fa 0%, #eef2f7 100%);
}

.header {
  position: relative;
  z-index: 10;
  background: rgba(255, 255, 255, 0.96);
}

.content {
  box-sizing: border-box;
  height: calc(100vh - 96rpx);
  padding: 0rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
}

.hero-card,
.section-card,
.state-card,
.tips-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(103, 126, 167, 0.08);
  box-shadow: 0 20rpx 50rpx rgba(24, 62, 107, 0.08);
}

.hero-card {
  background: linear-gradient(135deg, #ffffff 0%, #eff7ff 54%, #f8fbff 100%);
}

.hero-title,
.state-title,
.section-title,
.tips-title {
  display: block;
  color: #17314a;
  font-size: 32rpx;
  font-weight: 700;
}

.hero-desc,
.state-desc,
.section-desc,
.tips-item {
  display: block;
  margin-top: 14rpx;
  color: #6a7d90;
  font-size: 24rpx;
  line-height: 1.8;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-tag {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: #0c7f58;
  background: rgba(12, 127, 88, 0.1);
  font-size: 22rpx;
  font-weight: 600;
}

.section-tag-warn {
  color: #8a5b00;
  background: rgba(255, 184, 0, 0.14);
}

.section-tag-free {
  color: #1f4f78;
  background: rgba(31, 122, 224, 0.1);
}

.summary-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 22rpx;
}

.summary-item {
  width: calc(50% - 10rpx);
  margin-bottom: 18rpx;
  box-sizing: border-box;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f6f9fc;
}

.summary-label {
  display: block;
  color: #7b8798;
  font-size: 22rpx;
}

.summary-value {
  display: block;
  margin-top: 10rpx;
  color: #1f3349;
  font-size: 26rpx;
  line-height: 1.6;
  word-break: break-all;
}

.detail-panel {
  margin-top: 6rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(31, 122, 224, 0.08);
}

.detail-title {
  display: block;
  color: #1d3552;
  font-size: 24rpx;
  font-weight: 600;
}

.detail-desc,
.detail-meta {
  display: block;
  margin-top: 10rpx;
  color: #4e647b;
  font-size: 24rpx;
  line-height: 1.8;
}

.form-panel {
  margin: 20rpx 0 24rpx;
}

.action-row {
  margin-top: 22rpx;
}

.action-row-split {
  display: flex;
  gap: 16rpx;
}

.list-wrap {
  margin-top: 20rpx;
}

.list-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f7f9fc;
}

.list-card + .list-card {
  margin-top: 20rpx;
}

.list-card-pending {
  background: rgba(255, 184, 0, 0.08);
}

.list-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.list-card-title {
  color: #17314a;
  font-size: 28rpx;
  font-weight: 700;
}

.list-card-tag {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #0c7f58;
  background: rgba(12, 127, 88, 0.12);
  font-size: 22rpx;
  font-weight: 600;
}

.list-card-tag-warn {
  color: #8a5b00;
  background: rgba(255, 184, 0, 0.18);
}

.compact-grid {
  margin-top: 18rpx;
}

.detail-panel-warn {
  background: rgba(255, 184, 0, 0.12);
}

.empty-card {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #f7f9fc;
}

.empty-title {
  display: block;
  color: #17314a;
  font-size: 28rpx;
  font-weight: 700;
}

.empty-desc {
  display: block;
  margin-top: 10rpx;
  color: #6a7d90;
  font-size: 24rpx;
  line-height: 1.8;
}

.ghost-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 24rpx;
  margin: 0;
  border: none;
  border-radius: 999rpx;
  color: #1f4f78;
  background: #e7f1fb;
  font-size: 26rpx;
  font-weight: 600;
}

.ghost-btn-light {
  background: rgba(31, 122, 224, 0.08);
}

.ghost-btn::after {
  border: none;
}

.footer-placeholder {
  height: 40rpx;
}
