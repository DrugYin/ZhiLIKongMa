/* pages/student/training/training.wxss */
.fixed-header {
  position: fixed;
  top: 0;
  right: 0;
  left: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.96);
}

.navbar-wrapper {
  background: rgba(255, 255, 255, 0.96);
}

.dropdown-wrapper {
  padding: 0 24rpx 20rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 20rpx 40rpx rgba(31, 78, 121, 0.08);
}

.dropdown-menu {
  width: 100%;
}

.content {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 188rpx 24rpx 40rpx;
  background: linear-gradient(180deg, #f7f8fa 0%, #eef2f7 100%);
}
