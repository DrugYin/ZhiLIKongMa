/* pages/student/mine/mine.wxss */

.header {
  width: 100%;
}

.content {
  /* min-height: 100vh; */
  width: 100%;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #728af6 0%, #e5cefd 100%);
  border-radius: 25rpx;
  width: 80%;
  margin: 40rpx auto;
  padding: 60rpx 40rpx;
}

.avatar {
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.user-info {
  display: flex;
  flex-direction: column;
  margin-left: 20rpx;
  margin-right: auto;
  font-size: 36rpx;
  color: #000;
  font-weight: bold;
}

.login-btn {
  background-color: rgba(255, 255, 255, 0.2);
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.login-btn text {
  font-size: 24rpx;
  color: #000;
}

/* 积分卡片 */
.points-card {
  display: flex;
  justify-content: center;
  margin: 40rpx auto;
  width: 90%;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.points-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 60rpx;
}

.points-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.points-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 8rpx;
}

.points-label {
  font-size: 24rpx;
  color: #999;
}

.function-card {
  margin: 40rpx auto;
  width: 90%;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.function-list {
  width: 100% !important;
  margin: auto !important;
}
