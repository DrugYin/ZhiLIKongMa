/* pages/student/setting/setting.wxss */

.header {
  position: fixed;
  top: 0;
}

.content {
  min-height: 100vh;
  width: 100%;
  background-color: #f3f3f3;
  padding-top: 20rpx;
}

.avatar-wrapper {
  padding: 0;
  width: 80px !important;
  border-radius: 8px;
}

.avatar {
  display: block;
  width: 80px;
  height: 80px;
}

.avatar-text {
  display: block;
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-top: 8rpx;
}

.info-wrapper {
  margin-top: 50rpx;
  padding: 16rpx;
  width: 85%;
  background-color: #fff;
  border-radius: 16rpx;
  margin-left: auto;
  margin-right: auto;
}

.info-title {
  font-size: 28rpx;
  color: #333;
  margin-left: 30rpx;
}

.custom-required-label::after {
  content: '*';
  color: red;
  font-size: 32rpx;
  margin-left: 4rpx;
}

.action-wrapper {
  margin-top: 50rpx;
  padding: 16rpx;
  margin-left: auto;
  margin-right: auto;
  text-align: center;
}
