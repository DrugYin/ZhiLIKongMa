<!--pages/student/index.wxml-->
<view class="container">
  <view class="header">
    <custom-navbar placeholder="{{true}}" title="智力控码" />
  </view>

  <scroll-view class="content" scroll-y enhanced>
    <view class="hero-card">
      <view class="hero-top">
        <view class="hero-copy">
          <text class="hero-eyebrow">{{isLoggedIn ? '学生学习看板' : '学生主页'}}</text>
          <text class="hero-title">{{heroTitle}}</text>
          <text class="hero-desc">{{heroDesc}}</text>
        </view>
        <text class="role-tag">{{isLoggedIn ? '学习中' : '游客'}}</text>
      </view>

      <view class="summary-grid">
        <view class="summary-item">
          <text class="summary-label">当前积分</text>
          <text class="summary-value">{{summary.points}}</text>
        </view>
        <view class="summary-item">
          <text class="summary-label">已加入班级</text>
          <text class="summary-value">{{summary.joinedClasses}}</text>
        </view>
        <view class="summary-item">
          <text class="summary-label">待审核申请</text>
          <text class="summary-value">{{summary.pendingApplications}}</text>
        </view>
        <view class="summary-item">
          <text class="summary-label">本周排名</text>
          <text class="summary-value">{{summary.weeklyRankText}}</text>
        </view>
      </view>

      <view class="hero-actions">
        <button wx:if="{{isLoggedIn}}" class="primary-btn" bindtap="goToTaskCenter">继续学习</button>
        <button wx:else class="primary-btn" bindtap="goLogin">立即登录</button>
        <button class="ghost-btn" bindtap="goToClass">查看班级</button>
      </view>
    </view>

    <view wx:if="{{showNotice}}" class="section-card notice-card">
      <view class="section-header">
        <text class="section-title">学习提醒</text>
        <text class="notice-close" bindtap="closeNotice">关闭</text>
      </view>
      <text class="section-desc">{{notice}}</text>
    </view>

    <view class="section-card">
      <view class="section-header">
        <text class="section-title">每周任务</text>
        <text class="section-extra">{{featuredTask.deadlineText}}</text>
      </view>
      <view class="featured-task-panel" bindtap="handleFeaturedTaskTap">
        <view class="featured-task-head">
          <text class="focus-title">{{featuredTask.title}}</text>
          <text class="featured-task-link">{{featuredTask.taskId ? '查看详情' : '打开任务中心'}}</text>
        </view>
        <view class="weekly-tag-row">
          <text class="weekly-tag">{{featuredTask.projectText}}</text>
          <text class="weekly-tag weekly-tag-light">{{featuredTask.classText}}</text>
          <text class="weekly-tag" style="{{featuredTask.statusStyle}}">{{featuredTask.statusText}}</text>
        </view>
        <text class="focus-desc">{{featuredTask.description}}</text>
      </view>

      <view class="weekly-summary-row">
        <view class="weekly-summary-item">
          <text class="weekly-summary-label">本周任务数</text>
          <text class="weekly-summary-value">{{featuredTask.weeklyTaskCount}}</text>
        </view>
        <view class="weekly-summary-item">
          <text class="weekly-summary-label">已提交任务</text>
          <text class="weekly-summary-value">{{featuredTask.submittedCount}}</text>
        </view>
      </view>

      <view class="focus-progress">
        <view class="progress-track">
          <view class="progress-bar" style="width: {{featuredTask.progressPercent}}%;"></view>
        </view>
        <text class="progress-text">{{featuredTask.progressText}}</text>
      </view>

      <button class="primary-btn block-btn" bindtap="goToTaskCenter">打开任务中心</button>
    </view>

    <view class="section-card">
      <view class="section-header">
        <text class="section-title">快速入口</text>
        <text class="section-extra">常用功能</text>
      </view>
      <view class="quick-grid">
        <view
          wx:for="{{quickActions}}"
          wx:key="key"
          class="quick-card"
          data-key="{{item.key}}"
          bindtap="handleQuickAction"
        >
          <view class="quick-mark">{{item.mark}}</view>
          <text class="quick-title">{{item.title}}</text>
          <text class="quick-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-header">
        <text class="section-title">今日建议</text>
        <text class="section-extra">按顺序完成</text>
      </view>
      <view class="tip-list">
        <text wx:for="{{focusList}}" wx:key="*this" class="tip-item">{{index + 1}}. {{item}}</text>
      </view>
    </view>

    <view class="footer-placeholder"></view>
  </scroll-view>
</view>
