.container {
  /* min-height: 100vh; */
  background: linear-gradient(180deg, #f7f8fa 0%, #eef2f7 100%);
}

.header {
  position: relative;
  z-index: 10;
  width: 100%;
  background: rgba(255, 255, 255, 0.96);
}

.navbar-wrapper,
.tabs-wrapper {
  background: rgba(255, 255, 255, 0.96);
}

.tabs-wrapper {
  border-top: 1rpx solid rgba(223, 229, 237, 0.8);
}

.content {
  box-sizing: border-box;
  height: calc(100vh - 188rpx);
  padding: 24rpx 24rpx calc(180rpx + env(safe-area-inset-bottom));
}

.hero-card,
.section-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(103, 126, 167, 0.08);
  box-shadow: 0 20rpx 50rpx rgba(24, 62, 107, 0.08);
}

.hero-card {
  background: linear-gradient(135deg, #ffffff 0%, #eef6ff 54%, #f8fbff 100%);
}

.hero-eyebrow {
  display: block;
  color: #1f7ae0;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.hero-title,
.section-title,
.current-name,
.podium-name,
.rank-name {
  display: block;
  color: #17314a;
  font-weight: 700;
}

.hero-title {
  margin-top: 12rpx;
  font-size: 38rpx;
  line-height: 1.4;
}

.hero-desc,
.section-extra,
.podium-meta,
.current-meta,
.rank-meta {
  display: block;
  color: #65788c;
  font-size: 24rpx;
  line-height: 1.8;
}

.hero-desc {
  margin-top: 14rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-title {
  font-size: 30rpx;
}

.section-extra {
  font-size: 22rpx;
}

.summary-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 18rpx 0;
  margin-top: 24rpx;
}

.summary-item,
.podium-item,
.current-card,
.rank-item {
  box-sizing: border-box;
}

.summary-item {
  width: calc(50% - 10rpx);
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f6f9fc;
}

.summary-label {
  display: block;
  color: #7b8798;
  font-size: 22rpx;
}

.summary-value {
  display: block;
  margin-top: 10rpx;
  color: #1f3349;
  font-size: 28rpx;
  font-weight: 700;
}

.podium-list,
.rank-list {
  margin-top: 18rpx;
}

.podium-item,
.rank-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(223, 229, 237, 0.9);
}

.podium-item:last-child,
.rank-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.podium-rank,
.rank-order {
  width: 60rpx;
  height: 60rpx;
  border-radius: 18rpx;
  background: #e7f1fb;
  color: #1f7ae0;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 60rpx;
  text-align: center;
  flex-shrink: 0;
}

.rank-top-1 .podium-rank {
  background: rgba(247, 181, 0, 0.18);
  color: #8a5b00;
}

.rank-top-2 .podium-rank {
  background: rgba(157, 169, 182, 0.18);
  color: #55616d;
}

.rank-top-3 .podium-rank {
  background: rgba(205, 127, 50, 0.18);
  color: #8a5a28;
}

.podium-copy,
.rank-copy {
  flex: 1;
  min-width: 0;
}

.podium-name,
.rank-name,
.current-name {
  font-size: 28rpx;
}

.podium-score,
.rank-score {
  flex-shrink: 0;
  color: #17314a;
  font-size: 28rpx;
  font-weight: 700;
}

.current-card {
  background: linear-gradient(135deg, rgba(31, 122, 224, 0.08) 0%, rgba(47, 143, 87, 0.08) 100%);
}

.current-name {
  margin-top: 18rpx;
}

.current-meta {
  margin-top: 10rpx;
}

.current-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.current-pill {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.8);
  color: #1f4f78;
  font-size: 22rpx;
  font-weight: 600;
}

.rank-item-current {
  background: rgba(31, 122, 224, 0.06);
  border-radius: 22rpx;
  padding: 22rpx;
}

.footer-placeholder {
  height: 20rpx;
}
