.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f7f8fa 0%, #eef2f7 100%);
}

.header {
  position: relative;
  z-index: 10;
  background: rgba(255, 255, 255, 0.96);
}

.navbar-wrapper {
  background: rgba(255, 255, 255, 0.96);
}

.content {
  box-sizing: border-box;
  height: calc(100vh - 96rpx);
  padding: 24rpx 24rpx calc(180rpx + env(safe-area-inset-bottom));
}

.hero-card,
.section-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(103, 126, 167, 0.08);
  box-shadow: 0 20rpx 50rpx rgba(24, 62, 107, 0.08);
}

.hero-card {
  background: linear-gradient(135deg, #ffffff 0%, #eef6ff 54%, #f8fbff 100%);
}

.hero-eyebrow {
  display: block;
  color: #1f7ae0;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.hero-title,
.section-title,
.quick-title,
.activity-text {
  display: block;
  color: #17314a;
  font-weight: 700;
}

.hero-title {
  margin-top: 12rpx;
  font-size: 38rpx;
  line-height: 1.4;
}

.hero-desc,
.section-extra,
.quick-desc,
.activity-time {
  display: block;
  color: #65788c;
  font-size: 24rpx;
  line-height: 1.8;
}

.hero-desc {
  margin-top: 14rpx;
}

.summary-grid,
.quick-grid,
.stats-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 18rpx 0;
  margin-top: 24rpx;
}

.summary-item,
.quick-card {
  width: calc(50% - 10rpx);
  box-sizing: border-box;
  padding: 22rpx;
  border-radius: 22rpx;
}

.summary-item {
  background: #f6f9fc;
}

.summary-label,
.stats-label {
  display: block;
  color: #7b8798;
  font-size: 22rpx;
}

.summary-value,
.stats-value {
  display: block;
  margin-top: 10rpx;
  color: #1f3349;
  font-size: 30rpx;
  font-weight: 700;
}

.hero-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.primary-btn,
.ghost-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 24rpx;
  margin: 0;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.primary-btn::after,
.ghost-btn::after {
  border: none;
}

.primary-btn {
  color: #ffffff;
  background: linear-gradient(135deg, #1f7ae0 0%, #4a8ff5 100%);
}

.ghost-btn {
  color: #1f4f78;
  background: #e7f1fb;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-title {
  font-size: 30rpx;
}

.section-extra {
  font-size: 22rpx;
}

.stats-item {
  width: calc(33.333% - 12rpx);
  box-sizing: border-box;
  padding: 22rpx 18rpx;
  border-radius: 22rpx;
  background: #f7f9fc;
  text-align: center;
}

.quick-card {
  background: #f7f9fc;
}

.quick-mark {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: rgba(31, 122, 224, 0.12);
  color: #1f7ae0;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 64rpx;
  text-align: center;
}

.quick-title {
  margin-top: 18rpx;
  font-size: 28rpx;
}

.quick-desc {
  margin-top: 10rpx;
}

.activity-list {
  margin-top: 18rpx;
}

.activity-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(223, 229, 237, 0.9);
}

.activity-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.activity-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #1f7ae0;
  margin-top: 12rpx;
  flex-shrink: 0;
}

.activity-copy {
  flex: 1;
  min-width: 0;
}

.activity-text {
  font-size: 28rpx;
}

.activity-time {
  margin-top: 8rpx;
}

.footer-placeholder {
  height: 20rpx;
}
