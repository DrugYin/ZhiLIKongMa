/* pages/teacher/index.wxss */
.header {
  width: 100%;
  overflow: visible;
}

.navbar-wrapper {
  background-color: transparent;
}

.content {
  width: 85%;
  padding: 0 30rpx 40rpx;
}

/* 顶部欢迎区 */
.welcome-section {
  padding: 40rpx 0 30rpx;
}

.welcome-text {
  color: #000;
}

.greeting {
  font-size: 36rpx;
  font-weight: normal;
}

.teacher-name {
  font-size: 48rpx;
  font-weight: bold;
}

/* 核心待办卡片 */
.pending-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.pending-content {
  display: flex;
  align-items: center;
  flex: 1;
}

.pending-icon {
  font-size: 64rpx;
  margin-right: 24rpx;
}

.pending-info {
  display: flex;
  flex-direction: column;
}

.pending-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.pending-desc {
  font-size: 24rpx;
  color: #999;
}

.pending-action {
  display: flex;
  align-items: center;
  padding-left: 20rpx;
}

.action-text {
  font-size: 28rpx;
  color: #667eea;
  margin-right: 8rpx;
}

.action-arrow {
  font-size: 48rpx;
  color: #667eea;
  line-height: 1;
}

/* 统计区域 */
.stats-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.stats-cards {
  display: flex;
  justify-content: space-around;
}

.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 快速操作 */
.quick-actions {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 30rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.action-name {
  font-size: 24rpx;
  color: #666;
}

/* 动态区域 */
.activities-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.view-all {
  font-size: 24rpx;
  color: #667eea;
}

.activities-list {
  display: flex;
  flex-direction: column;
}

.activity-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
}

.activity-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #667eea;
  margin-top: 10rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.activity-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.activity-text {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.activity-time {
  font-size: 22rpx;
  color: #999;
}
