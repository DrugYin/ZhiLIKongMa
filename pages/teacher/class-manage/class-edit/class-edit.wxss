/* pages/teacher/class-manage/class-edit/class-edit.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f7f8fa 0%, #eef2f7 100%);
}

.header {
  position: relative;
  z-index: 20;
  background-color: #ffffff;
}

.content {
  box-sizing: border-box;
  height: calc(100vh - 96rpx);
  padding: 24rpx;
}

.hero-card,
.summary-card,
.form-card,
.tips-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background-color: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(31, 35, 41, 0.06);
}

.hero-card {
  background: linear-gradient(135deg, #ffffff 0%, #eef6ff 55%, #f5f9ff 100%);
  border: 1rpx solid rgba(22, 93, 255, 0.08);
}

.hero-copy {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hero-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-title,
.card-title,
.summary-title {
  color: #111827;
  font-weight: 600;
}

.hero-title {
  font-size: 36rpx;
}

.hero-desc {
  color: #4b5563;
  font-size: 26rpx;
  line-height: 1.7;
}

.summary-title,
.card-title {
  margin-bottom: 20rpx;
  font-size: 30rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.summary-item {
  padding: 20rpx;
  border-radius: 20rpx;
  background-color: #f7f8fa;
}

.summary-label {
  display: block;
  margin-bottom: 10rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.summary-value {
  color: #111827;
  font-size: 28rpx;
  font-weight: 600;
}

.textarea-wrapper {
  overflow: hidden;
  border-radius: 20rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-item {
  color: #4b5563;
  font-size: 24rpx;
  line-height: 1.7;
}

.loading-panel {
  padding: 32rpx 0 12rpx;
  text-align: center;
}

.loading-text {
  color: #9ca3af;
  font-size: 24rpx;
}

.footer-placeholder {
  height: 160rpx;
}

.footer {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  box-sizing: border-box;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.06);
  backdrop-filter: blur(16rpx);
}
