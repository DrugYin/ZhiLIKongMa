.header {
  position: fixed;
  width: 100%;
  z-index: 100;
}

.navbar-wrapper {
  background-color: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(18rpx);
}

.dropdown-wrapper {
  padding: 0 24rpx 20rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 20rpx 40rpx rgba(31, 78, 121, 0.08);
}

.content {
  margin-top: 38%;
  padding: 20rpx 20rpx 220rpx;
  padding-bottom: calc(220rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
}

.summary-card,
.task-card,
.state-card {
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(103, 126, 167, 0.08);
  border-radius: 32rpx;
  box-shadow: 0 24rpx 60rpx rgba(24, 62, 107, 0.08);
}

.summary-card,
.task-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.summary-header,
.card-top,
.summary-grid,
.card-footer,
.summary-item,
.tag-row,
.action-group {
  display: flex;
}

.summary-header {
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.summary-title,
.task-title,
.state-title {
  color: #16324c;
  font-weight: 700;
}

.summary-title,
.state-title {
  font-size: 32rpx;
}

.summary-desc,
.state-desc,
.time-text {
  color: #7a8797;
  font-size: 24rpx;
  line-height: 1.8;
}

.summary-grid {
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 24rpx;
}

.summary-item {
  width: calc(50% - 10rpx);
  flex-direction: column;
  margin-bottom: 18rpx;
  box-sizing: border-box;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f6f9fc;
}

.summary-label {
  color: #7b8798;
  font-size: 22rpx;
}

.summary-value {
  margin-top: 10rpx;
  color: #1f3349;
  font-size: 34rpx;
  font-weight: 700;
}

.card-top {
  align-items: flex-start;
  justify-content: space-between;
}

.card-title-group {
  flex: 1;
  min-width: 0;
  margin-right: 24rpx;
}

.task-title {
  display: block;
  font-size: 34rpx;
  line-height: 1.4;
  word-break: break-all;
}

.task-project {
  display: inline-flex;
  margin-top: 14rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #0f6b66;
  background: rgba(15, 107, 102, 0.1);
}

.status-tag,
.plain-tag {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-published {
  color: #0c7f58;
  background: rgba(12, 127, 88, 0.1);
}

.status-draft {
  color: #8a5b00;
  background: rgba(255, 184, 0, 0.14);
}

.status-closed {
  color: #8e3d3b;
  background: rgba(239, 107, 99, 0.12);
}

.tag-row {
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.plain-tag {
  color: #1f4f78;
  background: rgba(31, 122, 224, 0.1);
}

.plain-tag-light {
  color: #51697f;
  background: #eef3f8;
}

.task-meta-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 28rpx;
}

.meta-item {
  width: calc(50% - 10rpx);
  margin-bottom: 18rpx;
  box-sizing: border-box;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f6f9fc;
}

.meta-label {
  display: block;
  font-size: 22rpx;
  color: #7b8798;
}

.meta-value {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #1f3349;
  word-break: break-all;
}

.task-desc {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-left: 6rpx solid #1f7ae0;
  border-radius: 20rpx;
  background: rgba(31, 122, 224, 0.08);
  font-size: 24rpx;
  line-height: 1.8;
  color: #35536c;
}

.card-footer {
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 26rpx;
}

.time-group {
  flex: 1;
  min-width: 0;
  margin-right: 20rpx;
}

.time-text {
  display: block;
}

.action-btn {
  min-width: 132rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 24rpx;
  margin: 0;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.action-btn + .action-btn {
  margin-left: 16rpx;
}

.action-btn::after {
  border: none;
}

.action-btn-secondary {
  color: #1f4f78;
  background: #e7f1fb;
}

.action-btn-danger {
  color: #ffffff;
  background: linear-gradient(135deg, #ef6b63 0%, #d84a55 100%);
}

.state-card {
  padding: 56rpx 36rpx;
  text-align: center;
}

.empty-card {
  margin-top: 20rpx;
}
