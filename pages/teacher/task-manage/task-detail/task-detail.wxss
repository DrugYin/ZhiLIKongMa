.container {
  height: 100vh;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  overflow: hidden;
  background: linear-gradient(180deg, #f7f8fa 0%, #eef2f7 100%);
}

.header {
  position: relative;
  flex-shrink: 0;
  z-index: 20;
  background-color: rgba(255, 255, 255, 0.96);
}

.content {
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
  padding: 24rpx 24rpx calc(180rpx + env(safe-area-inset-bottom));
}

.hero-card,
.section-card,
.state-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(103, 126, 167, 0.08);
  box-shadow: 0 20rpx 50rpx rgba(24, 62, 107, 0.08);
}

.hero-card {
  background: linear-gradient(135deg, #ffffff 0%, #eef6ff 52%, #f5fbff 100%);
}

.hero-title-row,
.hero-actions,
.tag-row,
.summary-grid {
  display: flex;
}

.hero-title-row {
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-title-group {
  flex: 1;
  min-width: 0;
}

.hero-title,
.section-title,
.state-title {
  color: #16324c;
  font-weight: 700;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  line-height: 1.4;
  word-break: break-all;
}

.section-title,
.state-title {
  font-size: 30rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-subtitle,
.state-desc {
  display: block;
  margin-top: 12rpx;
  color: #6a7d90;
  font-size: 24rpx;
  line-height: 1.8;
}

.hero-desc,
.detail-desc {
  display: block;
  color: #35536c;
  font-size: 24rpx;
  line-height: 1.8;
}

.section-subtitle {
  max-width: 280rpx;
  color: #7a8797;
  font-size: 22rpx;
  line-height: 1.7;
  text-align: right;
}

.hero-desc {
  margin-top: 22rpx;
}

.status-tag,
.plain-tag {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-published {
  color: #0c7f58;
  background: rgba(12, 127, 88, 0.1);
}

.status-draft {
  color: #8a5b00;
  background: rgba(255, 184, 0, 0.14);
}

.status-closed {
  color: #8e3d3b;
  background: rgba(239, 107, 99, 0.12);
}

.tag-row {
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.plain-tag {
  color: #1f4f78;
  background: rgba(31, 122, 224, 0.1);
}

.plain-tag-light {
  color: #51697f;
  background: #eef3f8;
}

.hero-actions {
  gap: 16rpx;
  margin-top: 24rpx;
}

.ghost-btn,
.danger-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 26rpx;
  margin: 0;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.ghost-btn::after,
.danger-btn::after {
  border: none;
}

.ghost-btn {
  color: #1f4f78;
  background: #e7f1fb;
}

.danger-btn {
  color: #ffffff;
  background: linear-gradient(135deg, #ef6b63 0%, #d84a55 100%);
}

.summary-grid {
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 22rpx;
}

.progress-overview {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(31, 122, 224, 0.12) 0%, rgba(31, 122, 224, 0.04) 100%);
}

.progress-top,
.progress-grid {
  display: flex;
}

.progress-top {
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.progress-label,
.progress-side-label,
.progress-item-label {
  display: block;
  color: #6d7f92;
  font-size: 22rpx;
}

.progress-value,
.progress-side-value,
.progress-item-value {
  display: block;
  color: #16324c;
  font-weight: 700;
}

.progress-value {
  margin-top: 10rpx;
  font-size: 44rpx;
  line-height: 1.2;
}

.progress-side {
  flex-shrink: 0;
  text-align: right;
}

.progress-side-value {
  margin-top: 10rpx;
  font-size: 30rpx;
}

.progress-track {
  margin-top: 22rpx;
  height: 16rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(22, 50, 76, 0.08);
}

.progress-bar {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #1f7ae0 0%, #2f8f57 100%);
}

.progress-note {
  display: block;
  margin-top: 18rpx;
  color: #5e7286;
  font-size: 22rpx;
  line-height: 1.7;
}

.progress-grid {
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 20rpx;
}

.progress-item {
  width: calc(50% - 10rpx);
  margin-bottom: 18rpx;
  box-sizing: border-box;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f6f9fc;
}

.progress-item-value {
  margin-top: 10rpx;
  font-size: 32rpx;
  line-height: 1.5;
  word-break: break-all;
}

.progress-item-value-small {
  font-size: 24rpx;
}

.summary-item {
  width: calc(50% - 10rpx);
  margin-bottom: 18rpx;
  box-sizing: border-box;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f6f9fc;
}

.summary-label {
  display: block;
  color: #7b8798;
  font-size: 22rpx;
}

.summary-value {
  display: block;
  margin-top: 10rpx;
  color: #1f3349;
  font-size: 26rpx;
  line-height: 1.6;
  word-break: break-all;
}

.detail-panel {
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(31, 122, 224, 0.08);
}

.detail-panel-soft {
  background: #f6f9fc;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 18rpx;
}

.task-image {
  width: 100%;
  height: 240rpx;
  border-radius: 22rpx;
  background: #eef3f8;
}

.file-list {
  margin-top: 18rpx;
}

.file-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 16rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 2rpx solid #e5e7eb;
}

.file-main {
  flex: 1;
  min-width: 0;
}

.file-name {
  display: block;
  color: #111827;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.6;
  word-break: break-all;
}

.file-meta {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.7;
}

.file-preview-text {
  flex-shrink: 0;
  color: #1f7ae0;
  font-size: 24rpx;
  font-weight: 600;
}

.state-card {
  text-align: center;
}

.footer-placeholder {
  height: 20rpx;
}
