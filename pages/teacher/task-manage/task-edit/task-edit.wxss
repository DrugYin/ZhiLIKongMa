.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f7f8fa 0%, #eef2f7 100%);
}

.header {
  position: relative;
  z-index: 20;
  background-color: #ffffff;
}

.content {
  box-sizing: border-box;
  height: calc(100vh - 96rpx);
  padding: 0 24rpx calc(24rpx + env(safe-area-inset-bottom));
}

.hero-card,
.summary-card,
.form-card,
.tips-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background-color: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(31, 35, 41, 0.06);
}

.hero-card {
  background: linear-gradient(135deg, #ffffff 0%, #eef6ff 55%, #f5f9ff 100%);
  border: 1rpx solid rgba(22, 93, 255, 0.08);
}

.hero-copy {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hero-title-row,
.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-title,
.card-title,
.summary-title,
.block-label {
  color: #111827;
  font-weight: 600;
}

.hero-title {
  font-size: 36rpx;
}

.hero-desc,
.section-hint,
.tip-item,
.loading-text,
.option-desc,
.upload-tip,
.section-side-text {
  color: #4b5563;
  font-size: 24rpx;
  line-height: 1.7;
}

.summary-title,
.card-title {
  margin-bottom: 20rpx;
  font-size: 30rpx;
}

.summary-grid,
.option-grid,
.difficulty-grid,
.picker-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.summary-item,
.option-card,
.difficulty-card,
.picker-card {
  border-radius: 20rpx;
}

.summary-item {
  padding: 20rpx;
  background-color: #f7f8fa;
}

.summary-label {
  display: block;
  margin-bottom: 10rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.summary-value {
  color: #111827;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.5;
  word-break: break-all;
}

.option-block {
  margin-top: 24rpx;
}

.option-block-last {
  margin-bottom: 4rpx;
}

.block-label {
  display: block;
  margin-bottom: 18rpx;
  font-size: 28rpx;
}

.option-card {
  min-height: 124rpx;
  box-sizing: border-box;
  padding: 22rpx;
  border: 2rpx solid #e5e7eb;
  background: #f8fafc;
}

.option-card-active {
  border-color: #1f7ae0;
  background: rgba(31, 122, 224, 0.08);
  box-shadow: 0 14rpx 28rpx rgba(31, 122, 224, 0.12);
}

.option-title,
.difficulty-label,
.picker-value,
.link-text {
  font-size: 26rpx;
}

.option-title,
.difficulty-label,
.picker-value {
  color: #111827;
  font-weight: 600;
}

.option-desc {
  display: block;
  margin-top: 10rpx;
}

.difficulty-grid {
  margin-bottom: 24rpx;
}

.difficulty-card {
  display: flex;
  align-items: center;
  padding: 22rpx 24rpx;
  border: 2rpx solid #e5e7eb;
  background: #f8fafc;
}

.difficulty-card-active {
  border-color: #1f7ae0;
  background: rgba(31, 122, 224, 0.08);
}

.difficulty-dot {
  width: 18rpx;
  height: 18rpx;
  margin-right: 14rpx;
  border-radius: 50%;
}

.section-hint {
  display: block;
  margin-top: 8rpx;
}

.link-text {
  color: #1f7ae0;
  font-weight: 600;
  line-height: 1.6;
}

.section-side-text {
  flex-shrink: 0;
  color: #6b7280;
}

.picker-card {
  padding: 24rpx;
  background: #f8fafc;
  border: 2rpx solid #e5e7eb;
}

.picker-label {
  display: block;
  margin-bottom: 12rpx;
  color: #6b7280;
  font-size: 22rpx;
}

.picker-placeholder {
  color: #9ca3af;
  font-weight: 400;
}

.textarea-wrapper {
  overflow: hidden;
  border-radius: 20rpx;
}

.upload-wrapper {
  margin-top: 8rpx;
}

.upload-wrapper-file {
  margin-top: 12rpx;
}

.file-toolbar {
  margin-top: 12rpx;
}

.file-add-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  margin: 0;
  border-radius: 20rpx;
  border: 2rpx dashed #b7c6d8;
  color: #1f4f78;
  background: #f7fbff;
  font-size: 26rpx;
  font-weight: 600;
}

.file-add-btn::after {
  border: none;
}

.file-list {
  margin-top: 18rpx;
}

.file-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 16rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 2rpx solid #e5e7eb;
}

.file-main {
  flex: 1;
  min-width: 0;
}

.file-name {
  display: block;
  color: #111827;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.6;
  word-break: break-all;
}

.file-meta,
.file-empty-text {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.7;
}

.file-delete {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #eef3f8;
  color: #7a8897;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 56rpx;
  text-align: center;
  flex-shrink: 0;
}

.file-empty {
  margin-top: 18rpx;
  padding: 28rpx 24rpx;
  border-radius: 20rpx;
  background: #f8fafc;
}

.upload-tip {
  display: block;
  margin-top: 18rpx;
  color: #6b7280;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.loading-panel {
  padding: 32rpx 0 12rpx;
  text-align: center;
}

.footer-placeholder {
  height: 160rpx;
}

.footer {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  box-sizing: border-box;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.06);
  backdrop-filter: blur(16rpx);
}
