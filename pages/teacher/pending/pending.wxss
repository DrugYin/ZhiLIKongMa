.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f7f8fa 0%, #eef2f7 100%);
}

.header {
  position: relative;
  z-index: 10;
  background: rgba(255, 255, 255, 0.96);
}

.navbar-wrapper {
  background: rgba(255, 255, 255, 0.96);
}

.content {
  box-sizing: border-box;
  height: calc(100vh - 96rpx);
  padding: 0rpx 24rpx calc(180rpx + env(safe-area-inset-bottom));
}

.hero-card,
.section-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(103, 126, 167, 0.08);
  box-shadow: 0 20rpx 50rpx rgba(24, 62, 107, 0.08);
}

.hero-card {
  background: linear-gradient(135deg, #ffffff 0%, #eef6ff 54%, #f8fbff 100%);
}

.hero-eyebrow {
  display: block;
  color: #1f7ae0;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.hero-title,
.section-title,
.review-name,
.empty-title {
  display: block;
  color: #17314a;
  font-weight: 700;
}

.hero-title {
  margin-top: 12rpx;
  font-size: 36rpx;
  line-height: 1.5;
}

.hero-desc,
.section-extra,
.review-meta,
.review-desc,
.empty-desc {
  display: block;
  color: #65788c;
  font-size: 24rpx;
  line-height: 1.8;
}

.hero-desc {
  margin-top: 14rpx;
}

.summary-grid,
.meta-grid,
.action-row {
  display: flex;
}

.summary-grid,
.meta-grid {
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 18rpx 0;
  margin-top: 24rpx;
}

.summary-item,
.meta-item {
  width: calc(50% - 10rpx);
  box-sizing: border-box;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f6f9fc;
}

.summary-label,
.meta-label,
.filter-label {
  display: block;
  color: #7b8798;
  font-size: 22rpx;
}

.summary-value,
.meta-value {
  display: block;
  margin-top: 10rpx;
  color: #1f3349;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.5;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-title {
  font-size: 30rpx;
}

.section-extra {
  font-size: 22rpx;
}

.filter-group + .filter-group {
  margin-top: 20rpx;
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.filter-pill {
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #f4f7fb;
  color: #5f7387;
  font-size: 24rpx;
}

.filter-pill-active {
  background: rgba(31, 122, 224, 0.12);
  color: #1f7ae0;
  font-weight: 600;
}

.review-list {
  margin-top: 18rpx;
}

.review-card + .review-card {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(223, 229, 237, 0.9);
}

.review-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.review-copy {
  flex: 1;
  min-width: 0;
}

.review-name {
  font-size: 28rpx;
}

.review-meta {
  margin-top: 10rpx;
}

.review-desc {
  margin-top: 16rpx;
}

.status-tag {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-pending {
  color: #8a5b00;
  background: rgba(255, 184, 0, 0.14);
}

.status-approved {
  color: #0c7f58;
  background: rgba(12, 127, 88, 0.1);
}

.status-rejected {
  color: #d84a55;
  background: rgba(239, 107, 99, 0.12);
}

.action-row {
  gap: 16rpx;
  margin-top: 20rpx;
}

.action-row-secondary {
  margin-top: 18rpx;
}

.primary-btn,
.ghost-btn,
.danger-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 24rpx;
  margin: 0;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.primary-btn::after,
.ghost-btn::after,
.danger-btn::after {
  border: none;
}

.primary-btn {
  color: #ffffff;
  background: linear-gradient(135deg, #1f7ae0 0%, #4a8ff5 100%);
}

.ghost-btn {
  color: #1f4f78;
  background: #e7f1fb;
}

.danger-btn {
  color: #ffffff;
  background: linear-gradient(135deg, #ef6b63 0%, #d84a55 100%);
}

.empty-card {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #f7f9fc;
}

.empty-title {
  font-size: 28rpx;
}

.empty-desc {
  margin-top: 10rpx;
}

.footer-placeholder {
  height: 20rpx;
}
