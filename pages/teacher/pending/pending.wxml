<!--pages/teacher/pending/pending.wxml-->
<view class="container">
  <view class="header">
    <view class="navbar-wrapper">
      <custom-navbar placeholder="{{true}}" title="智力控码" />
    </view>
  </view>
  <scroll-view class="content" scroll-y enhanced>
    <view wx:if="{{loading}}" class="section-card">
      <text class="empty-title">审核记录加载中</text>
      <text class="empty-desc">正在同步学生提交和当前审核状态。</text>
    </view>

    <block wx:else>
    <view class="hero-card">
      <text class="hero-eyebrow">审核中心</text>
      <text class="hero-title">先处理学生任务提交，再回到任务管理页继续维护。</text>
      <text class="hero-desc">这里展示当前教师名下任务的真实提交记录，审核结果会即时回写到学生侧状态。</text>

      <view class="summary-grid">
        <view class="summary-item">
          <text class="summary-label">全部记录</text>
          <text class="summary-value">{{stats.total}}</text>
        </view>
        <view class="summary-item">
          <text class="summary-label">待审核</text>
          <text class="summary-value">{{stats.pending}}</text>
        </view>
        <view class="summary-item">
          <text class="summary-label">已通过</text>
          <text class="summary-value">{{stats.approved}}</text>
        </view>
        <view class="summary-item">
          <text class="summary-label">已驳回</text>
          <text class="summary-value">{{stats.rejected}}</text>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-header">
        <text class="section-title">筛选条件</text>
        <text class="section-extra">快速定位</text>
      </view>

      <view class="filter-group">
        <text class="filter-label">审核状态</text>
        <view class="filter-row">
          <view
            wx:for="{{statusOptions}}"
            wx:key="value"
            class="filter-pill {{statusFilter === item.value ? 'filter-pill-active' : ''}}"
            data-value="{{item.value}}"
            bindtap="onStatusFilterChange"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="filter-group">
        <text class="filter-label">所属班级</text>
        <view class="filter-row">
          <view
            wx:for="{{classOptions}}"
            wx:key="value"
            class="filter-pill {{classFilter === item.value ? 'filter-pill-active' : ''}}"
            data-value="{{item.value}}"
            bindtap="onClassFilterChange"
          >
            {{item.label}}
          </view>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-header">
        <text class="section-title">审核列表</text>
        <text class="section-extra">{{displayRecords.length}} 条</text>
      </view>

      <view wx:if="{{displayRecords.length}}" class="review-list">
        <view wx:for="{{displayRecords}}" wx:key="id" class="review-card" data-id="{{item.id}}" bindtap="openRecordPopup">
          <view class="review-top">
            <view class="review-copy">
              <text class="review-name">{{item.studentName}}</text>
              <text class="review-meta">{{item.className}} · {{item.projectText}}</text>
            </view>
            <text class="status-tag status-{{item.status}}">{{item.statusText}}</text>
          </view>

          <text class="review-task-title">{{item.taskTitle}}</text>
          <text class="review-desc">{{item.summary}}</text>

          <view wx:if="{{item.feedbackText && item.status !== 'pending'}}" class="review-feedback">
            <text class="review-feedback-label">处理意见</text>
            <text class="review-feedback-text">{{item.feedbackText}}</text>
          </view>

          <view class="meta-grid">
            <view class="meta-item">
              <text class="meta-label">提交时间</text>
              <text class="meta-value">{{item.submittedAt}}</text>
            </view>
            <view class="meta-item">
              <text class="meta-label">材料概览</text>
              <text class="meta-value">{{item.attachmentText}}</text>
            </view>
            <view class="meta-item">
              <text class="meta-label">审核评分</text>
              <text class="meta-value">{{item.scoreText}}</text>
            </view>
            <view class="meta-item">
              <text class="meta-label">积分结果</text>
              <text class="meta-value">{{item.pointsText}} · {{item.overtimeText}}</text>
            </view>
          </view>

          <text class="review-link">{{item.status === 'pending' ? '点击查看详情并审核' : '点击查看完整审核信息'}}</text>
        </view>
      </view>

      <view wx:else class="empty-card">
        <text class="empty-title">当前筛选下没有记录</text>
        <text class="empty-desc">可以切换审核状态或班级条件，继续查看其它待办。</text>
      </view>
    </view>

    <view class="section-card">
      <view class="section-header">
        <text class="section-title">后续建议</text>
        <text class="section-extra">继续处理</text>
      </view>
      <view class="action-row action-row-secondary">
        <button class="ghost-btn" bindtap="goToTaskManage">前往任务管理</button>
      </view>
    </view>

    <view class="footer-placeholder"></view>
    </block>
  </scroll-view>

  <t-popup
    visible="{{popupVisible}}"
    placement="bottom"
    usingCustomNavbar="{{true}}"
    close-on-overlay-click="{{true}}"
    prevent-scroll-through="{{true}}"
    bind:visible-change="onPopupVisibleChange"
  >
    <view class="popup-shell">
      <view class="popup-header">
        <view class="popup-header-copy">
          <text class="popup-title">{{popupRecord ? popupRecord.taskTitle : '提交详情'}}</text>
          <text class="popup-subtitle">{{popupRecord ? popupRecord.studentName + ' · ' + popupRecord.className : '正在加载'}}</text>
        </view>
        <text wx:if="{{popupRecord}}" class="status-tag status-{{popupRecord.status}}">{{popupRecord.statusText}}</text>
      </view>

      <scroll-view class="popup-content" scroll-y enhanced>
        <view wx:if="{{popupLoading}}" class="popup-state-card">
          <text class="empty-title">详情加载中</text>
          <text class="empty-desc">正在同步提交说明、图片和附件。</text>
        </view>

        <block wx:elif="{{popupRecord}}">
          <view class="popup-card">
            <view class="popup-grid">
              <view class="popup-item">
                <text class="popup-label">提交时间</text>
                <text class="popup-value">{{popupRecord.submittedAt}}</text>
              </view>
              <view class="popup-item">
                <text class="popup-label">审核时间</text>
                <text class="popup-value">{{popupRecord.reviewedAt}}</text>
              </view>
              <view class="popup-item">
                <text class="popup-label">材料概览</text>
                <text class="popup-value">{{popupRecord.attachmentText}}</text>
              </view>
              <view class="popup-item">
                <text class="popup-label">当前积分</text>
                <text class="popup-value">{{popupRecord.pointsText}} · {{popupRecord.overtimeText}}</text>
              </view>
            </view>
          </view>

          <view class="popup-card">
            <text class="section-title">提交说明</text>
            <view class="popup-panel">
              <text class="review-desc">{{popupRecord.descriptionText}}</text>
            </view>
          </view>

          <view class="popup-card">
            <view class="section-header">
              <text class="section-title">提交图片</text>
              <text class="section-extra">{{popupRecord.imageCount}} 张</text>
            </view>

            <view wx:if="{{popupRecordDetail.imageList.length}}" class="popup-image-grid">
              <image
                wx:for="{{popupRecordDetail.imageList}}"
                wx:key="fileId"
                class="popup-image"
                src="{{item.url}}"
                mode="aspectFill"
                data-index="{{index}}"
                bindtap="onPreviewPopupImage"
              />
            </view>

            <view wx:else class="popup-panel popup-panel-soft">
              <text class="empty-desc">本次提交没有上传图片。</text>
            </view>
          </view>

          <view class="popup-card">
            <view class="section-header">
              <text class="section-title">附件文件</text>
              <text class="section-extra">{{popupRecord.fileCount}} 个</text>
            </view>

            <view wx:if="{{popupRecordDetail.attachmentFiles.length}}" class="popup-file-list">
              <view
                wx:for="{{popupRecordDetail.attachmentFiles}}"
                wx:key="file_id"
                class="popup-file-row"
                data-index="{{index}}"
                bindtap="onPreviewPopupFile"
              >
                <view class="popup-file-main">
                  <text class="popup-file-name">{{item.file_name || item.name}}</text>
                  <text class="popup-file-meta">点击预览 · {{item.sizeText || '大小待补充'}}</text>
                </view>
                <text class="popup-file-link">预览</text>
              </view>
            </view>

            <view wx:else class="popup-panel popup-panel-soft">
              <text class="empty-desc">本次提交没有上传附件。</text>
            </view>
          </view>

          <view wx:if="{{popupRecord.feedbackText && popupRecord.status !== 'pending'}}" class="popup-card">
            <text class="section-title">已处理意见</text>
            <view class="popup-panel">
              <text class="review-desc">{{popupRecord.feedbackText}}</text>
            </view>
          </view>

          <view wx:if="{{popupRecord.status === 'pending'}}" class="popup-card">
            <text class="section-title">审核操作</text>

            <view class="review-field">
              <text class="review-field-label">评分</text>
              <input
                class="review-input"
                type="digit"
                placeholder="可选，填写评分"
                value="{{reviewForm.score}}"
                data-field="score"
                bindinput="onReviewFieldChange"
              />
            </view>

            <view class="review-field">
              <text class="review-field-label">发放积分</text>
              <input
                class="review-input"
                type="number"
                placeholder="默认 0，可自定义发放积分"
                value="{{reviewForm.points}}"
                data-field="points"
                bindinput="onReviewFieldChange"
              />
            </view>

            <view class="review-field">
              <text class="review-field-label">处理意见</text>
              <textarea
                class="review-textarea"
                maxlength="{{300}}"
                placeholder="可填写审核意见；驳回时建议说明需要补充的内容"
                value="{{reviewForm.feedback}}"
                data-field="feedback"
                bindinput="onReviewFieldChange"
              />
            </view>

            <view class="action-row popup-action-row">
              <button class="danger-btn" disabled="{{processingId === popupRecord.id}}" catchtap="handleReject">驳回</button>
              <button class="primary-btn" disabled="{{processingId === popupRecord.id}}" catchtap="handleApprove">通过</button>
            </view>
          </view>

          <view class="popup-bottom-space"></view>
        </block>
      </scroll-view>
    </view>
  </t-popup>
</view>
