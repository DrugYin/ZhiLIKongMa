<!--pages/teacher/index.wxml-->
<view class="container">
  <view class="header">
    <view class="navbar-wrapper">
      <custom-navbar title="智力控码" />
    </view>
  </view>
  <view class="content">
    <!-- 顶部欢迎区 -->
    <view class="welcome-section">
      <view class="welcome-text">
        <text class="greeting">{{greeting}}，</text>
        <text class="teacher-name">{{userInfo.name || ''}}教练</text>
      </view>
    </view>

    <!-- 核心待办卡片 -->
    <view class="pending-card" bind:tap="goToReview">
      <view class="pending-content">
        <view class="pending-icon">⏰</view>
        <view class="pending-info">
          <text class="pending-title">待审核打卡</text>
          <text class="pending-desc">📝 {{pendingCount}}条记录待处理</text>
        </view>
      </view>
      <view class="pending-action" bind:tap="goToPending">
        <text class="action-text">立即审核</text>
        <text class="action-arrow">›</text>
      </view>
    </view>

    <!-- 本周数据概览 -->
    <view class="stats-section">
      <view class="section-title">本周数据概览</view>
      <view class="stats-cards">
        <view class="stat-card">
          <text class="stat-value">{{weeklyStats.totalStudents}}</text>
          <text class="stat-label">总学员</text>
        </view>
        <view class="stat-card">
          <text class="stat-value">{{weeklyStats.weeklyCheckIns}}</text>
          <text class="stat-label">本周打卡</text>
        </view>
        <view class="stat-card">
          <text class="stat-value">{{weeklyStats.completionRate}}%</text>
          <text class="stat-label">完成率</text>
        </view>
      </view>
    </view>

    <!-- 常用功能快速入口 -->
    <view class="quick-actions">
      <view class="action-item" bind:tap="goToMissionManage">
        <view class="action-icon">📋</view>
        <text class="action-name">任务管理</text>
      </view>
      <view class="action-item" bind:tap="goToPending">
        <view class="action-icon">✏️</view>
        <text class="action-name">提交审核</text>
      </view>
      <view class="action-item" bind:tap="goToClassManage">
        <view class="action-icon">👥</view>
        <text class="action-name">班级管理</text>
      </view>
    </view>

    <!-- 最新动态 -->
    <view class="activities-section">
      <view class="section-header">
        <text class="section-title">最新动态</text>
        <text class="view-all" bind:tap="viewAllActivities">查看全部</text>
      </view>
      <view class="activities-list">
        <view class="activity-item" wx:for="{{recentActivities}}" wx:key="id">
          <view class="activity-dot"></view>
          <view class="activity-content">
            <text class="activity-text">{{item.content}}</text>
            <text class="activity-time">{{item.time}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>