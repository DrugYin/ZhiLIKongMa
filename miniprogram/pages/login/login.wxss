/* 登录页 - 页面特有样式 */

/* 登录页使用居中布局，覆盖通用容器样式 */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: visible;
}

.header {
  width: 100%;
  z-index: 20;
  background-color: #ffffff;
}

.content {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 48rpx 32rpx 120rpx;
}

.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 920rpx;
  box-sizing: border-box;
  padding: 84rpx 80rpx 72rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 20rpx 50rpx rgba(24, 62, 107, 0.08);
  margin-bottom: 200rpx;
}

.logo {
  width: 208rpx;
  height: 208rpx;
  border-radius: 50%;
  margin-bottom: 36rpx;
}

.app-name {
  font-size: 46rpx;
  font-weight: 700;
  color: #17314a;
}

.login-desc {
  margin-top: 20rpx;
  margin-bottom: 56rpx;
  color: #65788c;
  font-size: 28rpx;
  line-height: 1.8;
  text-align: center;
}

.login-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  color: #fff;
  font-size: 30rpx;
  margin-bottom: 28rpx;
  background: linear-gradient(135deg, #1f7ae0 0%, #4a8ff5 100%);
}

.login-btn::after {
  border: none;
}

.skip-btn {
  padding: 20rpx 24rpx;
  color: #1f4f78;
  font-size: 26rpx;
}

.agreement {
  margin-top: 40rpx;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  font-size: 24rpx;
  line-height: 1.8;
  color: #7a8797;
  text-align: left;
}

.agreement-checkbox-group {
  flex: none;
  margin-top: 2rpx;
  margin-right: 12rpx;
  line-height: 1;
}

.agreement-checkbox {
  transform: scale(0.72);
  transform-origin: left top;
}

.agreement-text {
  flex: none;
}

.link {
  color: #1f7ae0;
}

.action-wrapper {
  margin-top: 24rpx;
  margin-left: auto;
  margin-right: auto;
  text-align: center;
}

.register-btn {
  width: 60%;
}
