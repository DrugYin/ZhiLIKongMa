<!--pages/student/points-log/points-log.wxml-->
<view class="container">
  <view class="header">
    <custom-navbar show-back="{{true}}" placeholder="{{true}}" title="积分明细" />
  </view>

  <!-- 筛选条件 -->
  <view class="filter-bar">
    <view
      wx:for="{{filterOptions}}"
      wx:key="value"
      class="filter-item {{filterType === item.value ? 'filter-item-active' : ''}}"
      data-value="{{item.value}}"
      bindtap="onFilterChange"
    >
      {{item.label}}
    </view>
  </view>

  <!-- 列表 -->
  <scroll-view
    class="list-container"
    scroll-y
    enhanced
    refresher-enabled
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onPullDownRefresh"
    bindscrolltolower="onReachBottom"
  >
    <!-- 空状态 -->
    <view wx:if="{{!loading && list.length === 0}}" class="empty-state">
      <text class="empty-text">暂无积分变动记录</text>
    </view>

    <!-- 列表内容 -->
    <view class="list-content">
      <view
        wx:for="{{list}}"
        wx:key="_id"
        class="log-item"
      >
        <view class="log-left">
          <view class="log-icon {{item.type === 'income' ? 'log-icon-income' : 'log-icon-expense'}}">
            {{item.type === 'income' ? '+' : '-'}}
          </view>
          <view class="log-info">
            <text class="log-source">{{item.remark || item.sourceText}}</text>
            <text class="log-time">{{item.formattedTime}}</text>
          </view>
        </view>
        <view class="log-right">
          <text class="log-amount {{item.type === 'income' ? 'amount-income' : 'amount-expense'}}">
            {{item.type === 'income' ? '+' : '-'}}{{item.amount}}
          </text>
          <text class="log-balance">余额 {{item.after_points}}</text>
        </view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-state">
      <text class="loading-text">加载中...</text>
    </view>
    <view wx:if="{{!hasMore && list.length > 0}}" class="no-more-state">
      <text class="no-more-text">没有更多了</text>
    </view>
  </scroll-view>
</view>
