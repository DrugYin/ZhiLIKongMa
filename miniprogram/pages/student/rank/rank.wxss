/* 学生排行榜 - 页面特有样式 */

.content {
  padding: 0rpx 24rpx calc(100rpx + env(safe-area-inset-bottom));
}

.navbar-wrapper,
.tabs-wrapper {
  background: rgba(255, 255, 255, 0.96);
}

.tabs-wrapper {
  border-top: 1rpx solid rgba(223, 229, 237, 0.8);
}

.current-name,
.podium-name,
.rank-name {
  display: block;
  color: #17314a;
  font-weight: 700;
}

.podium-meta,
.current-meta,
.rank-meta {
  display: block;
  color: #65788c;
  font-size: 24rpx;
  line-height: 1.8;
}

.podium-list,
.rank-list {
  margin-top: 18rpx;
}

.podium-item,
.rank-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(223, 229, 237, 0.9);
}

.podium-item:last-child,
.rank-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.podium-rank,
.rank-order {
  width: 60rpx;
  height: 60rpx;
  border-radius: 18rpx;
  background: #e7f1fb;
  color: #1f7ae0;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 60rpx;
  text-align: center;
  flex-shrink: 0;
}

.rank-top-1 .podium-rank {
  background: rgba(247, 181, 0, 0.18);
  color: #8a5b00;
}

.rank-top-2 .podium-rank {
  background: rgba(157, 169, 182, 0.18);
  color: #55616d;
}

.rank-top-3 .podium-rank {
  background: rgba(205, 127, 50, 0.18);
  color: #8a5a28;
}

.podium-copy,
.rank-copy {
  flex: 1;
  min-width: 0;
}

.podium-name,
.rank-name,
.current-name {
  font-size: 28rpx;
}

.podium-score,
.rank-score {
  flex-shrink: 0;
  color: #17314a;
  font-size: 28rpx;
  font-weight: 700;
}

.current-card {
  background: linear-gradient(135deg, rgba(31, 122, 224, 0.08) 0%, rgba(47, 143, 87, 0.08) 100%);
}

.current-name {
  margin-top: 18rpx;
}

.current-meta {
  margin-top: 10rpx;
}

.current-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.current-pill {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.8);
  color: #1f4f78;
  font-size: 22rpx;
  font-weight: 600;
}

.rank-item-current {
  background: rgba(31, 122, 224, 0.06);
  border-radius: 22rpx;
  padding: 22rpx;
}
