<!--pages/rank/rank.wxml-->
<view class="container">
  <view class="header">
    <view class="navbar-wrapper">
      <custom-navbar title="智力控码" placeholder="{{true}}" />
    </view>
    <view class="tabs-wrapper">
      <t-tabs value="{{rankType}}" bind:change="onTabsChange">
        <t-tab-panel label="周榜" value="week" />
        <t-tab-panel label="月榜" value="month" />
        <t-tab-panel label="总榜" value="total" />
      </t-tabs>
    </view>
  </view>

  <scroll-view class="content" scroll-y enhanced scroll-top="{{scrollTop}}">
    <view id="back-top-sentinel" style="height:1rpx;"></view>
    <view class="hero-card">
      <text class="hero-eyebrow">学习排行</text>
      <text class="hero-title">{{rankTitle}}</text>
      <text class="hero-desc">{{rankDesc}}</text>

      <view class="summary-grid">
        <view class="summary-item">
          <text class="summary-label">参与人数</text>
          <text class="summary-value">{{summary.participantCount}}</text>
        </view>
        <view class="summary-item">
          <text class="summary-label">我的位置</text>
          <text class="summary-value">{{summary.myRankText}}</text>
        </view>
        <view class="summary-item">
          <text class="summary-label">当前积分</text>
          <text class="summary-value">{{summary.myPoints}}</text>
        </view>
        <view class="summary-item">
          <text class="summary-label">当前维度</text>
          <text class="summary-value">{{rankType === 'week' ? '周榜' : rankType === 'month' ? '月榜' : '总榜'}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{loading}}" class="section-card state-card">
      <text class="state-title">排行榜加载中</text>
      <text class="state-desc">正在同步当前维度下的真实积分排名。</text>
    </view>

    <view wx:elif="{{!isLoggedIn}}" class="section-card state-card">
      <text class="state-title">登录后查看排行榜</text>
      <text class="state-desc">学生登录后可查看周榜、月榜和总榜的实时表现。</text>
      <button class="primary-btn state-btn" bindtap="goLogin">去登录</button>
    </view>

    <view wx:elif="{{errorText}}" class="section-card state-card">
      <text class="state-title">排行榜加载失败</text>
      <text class="state-desc">{{errorText}}</text>
      <button class="ghost-btn state-btn" bindtap="loadRankData">重新加载</button>
    </view>

    <view wx:elif="{{topThree.length}}" class="section-card">
      <view class="section-header">
        <text class="section-title">前三名</text>
        <text class="section-extra">当前高光</text>
      </view>
      <view class="podium-list">
        <view wx:for="{{topThree}}" wx:key="rank" class="podium-item {{item.rankClass}}">
          <view class="podium-rank">{{item.rank}}</view>
          <view class="podium-copy">
            <text class="podium-name">{{item.name}}</text>
            <text class="podium-meta">{{item.grade}} · {{item.badgeText}}</text>
          </view>
          <text class="podium-score">{{item.points}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{currentUserCard}}" class="section-card current-card">
      <view class="section-header">
        <text class="section-title">我的表现</text>
        <text class="section-extra">{{currentUserCard.rank}}</text>
      </view>
      <text class="current-name">{{currentUserCard.name}}</text>
      <text class="current-meta">{{currentUserCard.grade}} · {{currentUserCard.badgeText}}</text>
      <view class="current-summary">
        <text class="current-pill">排名 {{currentUserCard.rank}}</text>
        <text class="current-pill">积分 {{currentUserCard.points}}</text>
      </view>
    </view>

    <view wx:if="{{displayRanks.length}}" class="section-card">
      <view class="section-header">
        <text class="section-title">完整榜单</text>
        <text class="section-extra">第 4 名起</text>
      </view>
      <view class="rank-list">
        <view wx:for="{{displayRanks}}" wx:key="rank" class="rank-item {{item.isCurrentUser ? 'rank-item-current' : ''}}">
          <view class="rank-order">{{item.rank}}</view>
          <view class="rank-copy">
            <text class="rank-name">{{item.name}}</text>
            <text class="rank-meta">{{item.grade}} · {{item.trend}}</text>
          </view>
          <text class="rank-score">{{item.points}}</text>
        </view>
      </view>
    </view>

    <view wx:elif="{{!loading}}" class="section-card state-card">
      <text class="state-title">当前还没有榜单数据</text>
      <text class="state-desc">等有学生积分或审核数据产生后，这里会自动同步真实排行。</text>
    </view>

    <view class="footer-placeholder"></view>
  </scroll-view>

  <back-top visible="{{backTopVisible}}" bind:to-top="onBackToTop" />
</view>
