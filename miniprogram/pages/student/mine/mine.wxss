/* 学生我的页 - 页面特有样式 */

.profile-card {
  margin-top: 12rpx;
  background: linear-gradient(135deg, #ffffff 0%, #eef6ff 54%, #f8fbff 100%);
  padding: 24rpx;
  border-radius: 28rpx;
}

.profile-top {
  align-items: flex-start;
}

.profile-main {
  flex: 1;
  min-width: 0;
  gap: 18rpx;
}

.profile-copy {
  flex: 1;
  min-width: 0;
}

.avatar-image {
  width: 88rpx;
  height: 88rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: #eef3f8;
}

.profile-name {
  display: block;
  color: #17314a;
  font-size: 34rpx;
  font-weight: 700;
}

.profile-meta {
  display: block;
  margin-top: 10rpx;
  color: #65788c;
  font-size: 24rpx;
  line-height: 1.8;
}

.action-list {
  margin-top: 18rpx;
}

.action-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(223, 229, 237, 0.9);
}

.action-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.action-copy {
  flex: 1;
  min-width: 0;
}

.action-title {
  display: block;
  color: #17314a;
  font-weight: 700;
  font-size: 28rpx;
}

.action-desc {
  display: block;
  margin-top: 10rpx;
  color: #65788c;
  font-size: 24rpx;
  line-height: 1.8;
}

.action-arrow {
  flex-shrink: 0;
  color: #7a8797;
  font-size: 34rpx;
  line-height: 1;
}

.action-item-danger {
  border-bottom: none;
}

.action-title-danger,
.action-arrow-danger {
  color: #d84a55;
}
