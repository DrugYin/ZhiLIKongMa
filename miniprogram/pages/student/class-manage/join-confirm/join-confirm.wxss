/* 学生入班确认 - 页面特有样式 */

.hero-card {
  background: linear-gradient(135deg, #ffffff 0%, #f0f7ff 50%, #f8fbff 100%);
}

.hero-title {
  font-size: 32rpx;
}

.detail-title {
  display: block;
  color: #17314a;
  font-size: 32rpx;
  font-weight: 700;
}

.detail-desc {
  display: block;
  margin-top: 14rpx;
  color: #6b7d8f;
  font-size: 24rpx;
  line-height: 1.8;
}

.section-tag {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: #0c7f58;
  background: rgba(12, 127, 88, 0.1);
  font-size: 22rpx;
  font-weight: 600;
}

.section-tag-danger {
  color: #b23c3c;
  background: rgba(239, 107, 99, 0.12);
}

.summary-value {
  font-size: 26rpx;
  line-height: 1.6;
  word-break: break-all;
}

.detail-panel {
  margin-top: 6rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(31, 122, 224, 0.08);
}

.textarea-wrapper {
  margin: 20rpx 0 24rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: #f7f9fc;
}

.status-hint-card {
  margin-bottom: 22rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(31, 122, 224, 0.08);
}

.status-hint-title {
  display: block;
  color: #17314a;
  font-size: 24rpx;
  font-weight: 700;
}

.status-hint-text {
  display: block;
  margin-top: 10rpx;
  color: #5f7387;
  font-size: 24rpx;
  line-height: 1.8;
}

.reason-textarea {
  width: 100%;
  min-height: 180rpx;
  color: #1f3349;
  font-size: 26rpx;
  line-height: 1.7;
}
