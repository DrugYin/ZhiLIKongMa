.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f7f8fa 0%, #eef2f7 100%);
}

.header {
  position: relative;
  z-index: 10;
  background: rgba(255, 255, 255, 0.96);
}

.content {
  box-sizing: border-box;
  height: calc(100vh - 96rpx);
  padding: 24rpx;
}

.hero-card,
.section-card,
.state-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(103, 126, 167, 0.08);
  box-shadow: 0 20rpx 50rpx rgba(24, 62, 107, 0.08);
}

.hero-card {
  background: linear-gradient(135deg, #ffffff 0%, #f0f7ff 50%, #f8fbff 100%);
}

.hero-eyebrow {
  display: block;
  color: #1f7ae0;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.hero-title,
.section-title,
.state-title,
.detail-title {
  display: block;
  color: #17314a;
  font-size: 32rpx;
  font-weight: 700;
}

.hero-title {
  margin-top: 12rpx;
}

.hero-desc,
.section-desc,
.state-desc,
.detail-desc {
  display: block;
  margin-top: 14rpx;
  color: #6b7d8f;
  font-size: 24rpx;
  line-height: 1.8;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-tag {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: #0c7f58;
  background: rgba(12, 127, 88, 0.1);
  font-size: 22rpx;
  font-weight: 600;
}

.section-tag-danger {
  color: #b23c3c;
  background: rgba(239, 107, 99, 0.12);
}

.summary-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 22rpx;
}

.summary-item {
  width: calc(50% - 10rpx);
  margin-bottom: 18rpx;
  box-sizing: border-box;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f6f9fc;
}

.summary-label {
  display: block;
  color: #7b8798;
  font-size: 22rpx;
}

.summary-value {
  display: block;
  margin-top: 10rpx;
  color: #1f3349;
  font-size: 26rpx;
  line-height: 1.6;
  word-break: break-all;
}

.detail-panel {
  margin-top: 6rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(31, 122, 224, 0.08);
}

.textarea-wrapper {
  margin: 20rpx 0 24rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: #f7f9fc;
}

.status-hint-card {
  margin-bottom: 22rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(31, 122, 224, 0.08);
}

.status-hint-title {
  display: block;
  color: #17314a;
  font-size: 24rpx;
  font-weight: 700;
}

.status-hint-text {
  display: block;
  margin-top: 10rpx;
  color: #5f7387;
  font-size: 24rpx;
  line-height: 1.8;
}

.reason-textarea {
  width: 100%;
  min-height: 180rpx;
  color: #1f3349;
  font-size: 26rpx;
  line-height: 1.7;
}

.footer-placeholder {
  height: 40rpx;
}
