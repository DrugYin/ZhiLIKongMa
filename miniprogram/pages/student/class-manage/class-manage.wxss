/* 学生班级管理 - 页面特有样式 */

.tips-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(103, 126, 167, 0.08);
  box-shadow: 0 20rpx 50rpx rgba(24, 62, 107, 0.08);
}

.hero-card {
  background: linear-gradient(135deg, #ffffff 0%, #eff7ff 54%, #f8fbff 100%);
}

.hero-title {
  font-size: 32rpx;
}

.tips-title {
  display: block;
  color: #17314a;
  font-size: 32rpx;
  font-weight: 700;
}

.tips-item {
  display: block;
  margin-top: 14rpx;
  color: #6a7d90;
  font-size: 24rpx;
  line-height: 1.8;
}

.section-tag {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: #0c7f58;
  background: rgba(12, 127, 88, 0.1);
  font-size: 22rpx;
  font-weight: 600;
}

.section-tag-warn {
  color: #8a5b00;
  background: rgba(255, 184, 0, 0.14);
}

.section-tag-free {
  color: #1f4f78;
  background: rgba(31, 122, 224, 0.1);
}

.detail-panel {
  margin-top: 6rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(31, 122, 224, 0.08);
}

.detail-title {
  display: block;
  color: #1d3552;
  font-size: 24rpx;
  font-weight: 600;
}

.detail-desc,
.detail-meta {
  display: block;
  margin-top: 10rpx;
  color: #4e647b;
  font-size: 24rpx;
  line-height: 1.8;
}

.form-panel {
  margin: 20rpx 0 24rpx;
}

.action-row {
  margin-top: 22rpx;
}

.action-row-split {
  display: flex;
  gap: 16rpx;
}

.list-wrap {
  margin-top: 20rpx;
}

.list-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f7f9fc;
}

.list-card + .list-card {
  margin-top: 20rpx;
}

.list-card-pending {
  background: rgba(255, 184, 0, 0.08);
}

.list-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.list-card-title {
  color: #17314a;
  font-size: 28rpx;
  font-weight: 700;
}

.list-card-tag {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #0c7f58;
  background: rgba(12, 127, 88, 0.12);
  font-size: 22rpx;
  font-weight: 600;
}

.list-card-tag-warn {
  color: #8a5b00;
  background: rgba(255, 184, 0, 0.18);
}

.compact-grid {
  margin-top: 18rpx;
}

.detail-panel-warn {
  background: rgba(255, 184, 0, 0.12);
}

.ghost-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 24rpx;
  margin: 0;
  border: none;
  border-radius: 999rpx;
  color: #1f4f78;
  background: #e7f1fb;
  font-size: 26rpx;
  font-weight: 600;
}

.ghost-btn-light {
  background: rgba(31, 122, 224, 0.08);
}

.ghost-btn::after {
  border: none;
}
