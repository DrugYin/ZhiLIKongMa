<view class="container">
  <view class="header">
    <custom-navbar title="{{pageTitle}}" showBack="{{true}}" placeholder="{{true}}" />
  </view>

  <scroll-view class="content" scroll-y enhanced bounces="{{false}}" show-scrollbar="{{false}}">
    <view wx:if="{{loading}}" class="state-card">
      <text class="state-title">提交记录加载中</text>
      <text class="state-desc">{{isAllRecords ? '正在同步你在所有任务中的提交历史。' : '正在同步该任务下的提交历史。'}}</text>
    </view>

    <block wx:elif="{{isAllRecords || taskInfo}}">
      <view class="hero-card">
        <view class="hero-top">
          <view class="hero-copy">
            <text class="hero-title">{{isAllRecords ? '全部提交记录' : taskInfo.titleText}}</text>
            <text class="hero-desc">{{isAllRecords ? '这里会汇总你在所有任务中的历史提交，方便统一回看审核状态与完成情况。' : (taskInfo.projectText + ' · ' + taskInfo.classText)}}</text>
          </view>
          <t-button size="small" theme="primary" bind:tap="handleHeroAction">
            {{isAllRecords ? '任务中心' : '再次提交'}}
          </t-button>
        </view>
        <text class="hero-tip">{{isAllRecords ? '首页和我的页都可以直接进入这里，统一查看你的所有提交沉淀。' : '任务详情页只展示最近两次提交，这里会继续承接更多提交记录。'}}</text>
      </view>

      <view class="summary-card">
        <view class="summary-grid">
          <view class="summary-item">
            <text class="summary-label">全部提交</text>
            <text class="summary-value">{{stats.total}}</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">待审核</text>
            <text class="summary-value">{{stats.pending}}</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">已通过</text>
            <text class="summary-value">{{stats.approved}}</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">已拒绝</text>
            <text class="summary-value">{{stats.rejected}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{records.length}}" class="record-list">
        <view wx:for="{{records}}" wx:key="_id" class="record-card" data-index="{{index}}" bindtap="openRecordPopup">
          <view wx:if="{{isAllRecords}}" class="record-task-head">
            <text class="record-task-title">{{item.taskTitle}}</text>
            <text class="record-task-meta">{{item.projectText}} · {{item.classText}}</text>
          </view>

          <view class="record-head">
            <view class="record-copy">
              <text class="record-title">第 {{item.submitNoText}} 次提交</text>
              <text class="record-time">{{item.submitTimeText}}</text>
            </view>
            <text class="status-tag" style="{{item.statusStyle}}">{{item.statusText}}</text>
          </view>

          <view class="record-meta-row">
            <text class="meta-tag">{{item.materialText}}</text>
            <text class="meta-tag">{{item.overtimeText}}</text>
            <text class="meta-tag">获取积分：{{item.pointsText}}</text>
          </view>

          <text class="record-desc">{{item.descriptionText}}</text>

          <view wx:if="{{item.feedbackText}}" class="feedback-panel">
            <text class="feedback-label">教师反馈</text>
            <text class="feedback-text">{{item.feedbackText}}</text>
          </view>

          <text class="record-link">点击查看提交详情与老师反馈附件</text>
        </view>
      </view>

      <view wx:else class="state-card">
        <text class="state-title">还没有提交记录</text>
        <text class="state-desc">{{isAllRecords ? '先去任务中心完成一次提交，后续所有历史都会沉淀在这里。' : '先去完成一次提交，后续所有历史都会沉淀在这里。'}}</text>
        <button class="ghost-btn" bindtap="handleEmptyAction">{{isAllRecords ? '去任务中心' : '去提交'}}</button>
      </view>

      <button wx:if="{{hasMore}}" class="load-more-btn" bindtap="onLoadMore" loading="{{loadingMore}}">
        {{loadingMore ? '加载中...' : '加载更多记录'}}
      </button>
    </block>

    <view wx:else class="state-card">
      <text class="state-title">当前任务暂不可查看</text>
      <text class="state-desc">可能是任务已下线，或者当前账号没有查看记录的权限。</text>
    </view>

    <view class="footer-placeholder"></view>
  </scroll-view>

  <t-popup
    visible="{{popupVisible}}"
    placement="bottom"
    usingCustomNavbar="{{true}}"
    close-on-overlay-click="{{true}}"
    prevent-scroll-through="{{true}}"
    bind:visible-change="onPopupVisibleChange"
  >
    <view class="detail-popup-shell">
      <view class="detail-popup-header">
        <view class="detail-popup-copy">
          <text class="detail-popup-title">{{popupRecord ? popupRecord.taskTitle : '提交详情'}}</text>
          <text class="detail-popup-subtitle">{{popupRecord ? '第 ' + popupRecord.submitNoText + ' 次提交 · ' + popupRecord.submitTimeText : '正在加载'}}</text>
        </view>
        <text wx:if="{{popupRecord}}" class="status-tag" style="{{popupRecord.statusStyle}}">{{popupRecord.statusText}}</text>
      </view>

      <scroll-view class="detail-popup-content" scroll-y enhanced>
        <view wx:if="{{popupLoading}}" class="state-card detail-state-card">
          <text class="state-title">提交详情加载中</text>
          <text class="state-desc">正在同步提交素材和老师反馈附件。</text>
        </view>

        <block wx:elif="{{popupRecord}}">
          <view class="detail-card">
            <view class="summary-grid">
              <view class="summary-item">
                <text class="summary-label">审核状态</text>
                <text class="summary-value">{{popupRecord.statusText}}</text>
              </view>
              <view class="summary-item">
                <text class="summary-label">获取积分</text>
                <text class="summary-value">{{popupRecord.pointsText}}</text>
              </view>
              <view class="summary-item">
                <text class="summary-label">提交材料</text>
                <text class="summary-value">{{popupRecord.materialText}}</text>
              </view>
              <view class="summary-item">
                <text class="summary-label">提交时效</text>
                <text class="summary-value">{{popupRecord.overtimeText}}</text>
              </view>
            </view>
          </view>

          <view class="detail-card">
            <text class="detail-section-title">提交说明</text>
            <text class="record-desc detail-desc">{{popupRecord.descriptionText}}</text>
          </view>

          <view class="detail-card">
            <view class="detail-section-head">
              <text class="detail-section-title">提交图片</text>
              <text class="section-extra">{{popupRecord.imageCount}} 张</text>
            </view>
            <view wx:if="{{popupRecordDetail.imageList.length}}" class="detail-image-grid">
              <image
                wx:for="{{popupRecordDetail.imageList}}"
                wx:key="fileId"
                class="detail-image"
                src="{{item.url}}"
                mode="aspectFill"
                data-type="submission"
                data-index="{{index}}"
                bindtap="onPreviewPopupImage"
              />
            </view>
            <view wx:else class="detail-empty-panel">
              <text class="state-desc">本次提交没有上传图片。</text>
            </view>
          </view>

          <view class="detail-card">
            <view class="detail-section-head">
              <text class="detail-section-title">提交附件</text>
              <text class="section-extra">{{popupRecord.fileCount}} 个</text>
            </view>
            <view wx:if="{{popupRecordDetail.attachmentFiles.length}}" class="detail-file-list">
              <view
                wx:for="{{popupRecordDetail.attachmentFiles}}"
                wx:key="file_id"
                class="detail-file-row"
                data-type="submission"
                data-index="{{index}}"
                bindtap="onPreviewPopupFile"
              >
                <view class="detail-file-main">
                  <text class="detail-file-name">{{item.file_name || item.name}}</text>
                  <text class="detail-file-meta">点击预览 · {{item.sizeText || '大小待补充'}}</text>
                </view>
                <text class="detail-file-link">预览</text>
              </view>
            </view>
            <view wx:else class="detail-empty-panel">
              <text class="state-desc">本次提交没有上传附件。</text>
            </view>
          </view>

          <view class="detail-card">
            <view class="detail-section-head">
              <text class="detail-section-title">教师反馈</text>
              <text class="section-extra">{{popupRecord.feedbackImageCount}} 张图 · {{popupRecord.feedbackFileCount}} 个附件</text>
            </view>
            <view wx:if="{{popupRecord.feedbackText}}" class="feedback-panel detail-feedback-panel">
              <text class="feedback-label">处理意见</text>
              <text class="feedback-text">{{popupRecord.feedbackText}}</text>
            </view>
            <view wx:else class="detail-empty-panel detail-empty-panel-top">
              <text class="state-desc">老师暂时还没有填写反馈说明。</text>
            </view>

            <view class="detail-subsection">
              <text class="detail-subtitle">反馈图片</text>
              <view wx:if="{{popupRecordDetail.feedbackImageList.length}}" class="detail-image-grid">
                <image
                  wx:for="{{popupRecordDetail.feedbackImageList}}"
                  wx:key="fileId"
                  class="detail-image"
                  src="{{item.url}}"
                  mode="aspectFill"
                  data-type="feedback"
                  data-index="{{index}}"
                  bindtap="onPreviewPopupImage"
                />
              </view>
              <view wx:else class="detail-empty-panel">
                <text class="state-desc">老师没有补充图片材料。</text>
              </view>
            </view>

            <view class="detail-subsection">
              <text class="detail-subtitle">反馈附件</text>
              <view wx:if="{{popupRecordDetail.feedbackAttachmentFiles.length}}" class="detail-file-list">
                <view
                  wx:for="{{popupRecordDetail.feedbackAttachmentFiles}}"
                  wx:key="file_id"
                  class="detail-file-row"
                  data-type="feedback"
                  data-index="{{index}}"
                  bindtap="onPreviewPopupFile"
                >
                  <view class="detail-file-main">
                    <text class="detail-file-name">{{item.file_name || item.name}}</text>
                    <text class="detail-file-meta">点击预览 · {{item.sizeText || '大小待补充'}}</text>
                  </view>
                  <text class="detail-file-link">预览</text>
                </view>
              </view>
              <view wx:else class="detail-empty-panel">
                <text class="state-desc">老师没有补充附件材料。</text>
              </view>
            </view>
          </view>

          <view class="detail-bottom-space"></view>
        </block>
      </scroll-view>
    </view>
  </t-popup>
</view>
