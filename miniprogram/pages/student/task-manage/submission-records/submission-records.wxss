/* 学生提交记录 - 页面特有样式 */

.summary-card,
.record-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(103, 126, 167, 0.08);
  box-shadow: 0 20rpx 50rpx rgba(24, 62, 107, 0.08);
}

.hero-card {
  background: linear-gradient(135deg, #ffffff 0%, #eef6ff 52%, #f5fbff 100%);
}

.hero-top,
.record-head {
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-copy,
.record-copy {
  flex: 1;
  min-width: 0;
}

.hero-title {
  display: block;
  font-size: 36rpx;
  line-height: 1.4;
  word-break: break-all;
  color: #16324c;
  font-weight: 700;
}

.record-title {
  display: block;
  font-size: 30rpx;
  color: #16324c;
  font-weight: 700;
}

.record-task-title {
  display: block;
  font-size: 28rpx;
  line-height: 1.5;
  color: #16324c;
  font-weight: 700;
}

.hero-desc,
.hero-tip,
.record-task-meta,
.record-time,
.feedback-text {
  display: block;
  color: #6a7d90;
  font-size: 24rpx;
  line-height: 1.8;
}

.hero-desc {
  margin-top: 12rpx;
}

.hero-tip {
  margin-top: 16rpx;
}

.summary-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.summary-item {
  width: calc(50% - 10rpx);
  margin-bottom: 18rpx;
  box-sizing: border-box;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f6f9fc;
}

.summary-item:nth-last-child(-n + 2) {
  margin-bottom: 0;
}

.summary-label {
  display: block;
  color: #7b8798;
  font-size: 22rpx;
}

.summary-value {
  display: block;
  margin-top: 10rpx;
  color: #1f3349;
  font-size: 30rpx;
  line-height: 1.5;
}

.status-tag,
.meta-tag {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.record-time {
  margin-top: 8rpx;
}

.record-task-head {
  margin-bottom: 18rpx;
}

.record-task-meta {
  margin-top: 8rpx;
}

.record-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.meta-tag {
  color: #51697f;
  background: #eef3f8;
}

.record-desc {
  display: block;
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
  border-left: 6rpx solid #1f7ae0;
  border-radius: 20rpx;
  background: rgba(31, 122, 224, 0.08);
  color: #35536c;
  font-size: 24rpx;
  line-height: 1.8;
}

.record-link {
  display: inline-flex;
  margin-top: 18rpx;
  color: #1f7ae0;
  font-size: 24rpx;
  font-weight: 600;
}

.feedback-panel {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.feedback-label {
  display: block;
  color: #6a7d90;
  font-size: 22rpx;
}

.ghost-btn,
.load-more-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  margin: 24rpx 0 0;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.ghost-btn::after,
.load-more-btn::after {
  border: none;
}

.ghost-btn {
  color: #1f4f78;
  background: #e7f1fb;
}

.load-more-btn {
  color: #1f7ae0;
  background: #ffffff;
  border: 2rpx solid rgba(31, 122, 224, 0.16);
}

.detail-popup-shell {
  box-sizing: border-box;
  height: 82vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  padding: 24rpx 24rpx 0;
  background: #f7f9fc;
  border-radius: 32rpx 32rpx 0 0;
}

.detail-popup-header,
.detail-section-head,
.detail-file-row {
  display: flex;
}

.detail-popup-header {
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  flex-shrink: 0;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(223, 229, 237, 0.9);
}

.detail-popup-copy,
.detail-file-main {
  flex: 1;
  min-width: 0;
}

.detail-popup-title,
.detail-section-title,
.detail-subtitle {
  display: block;
  color: #16324c;
  font-weight: 700;
}

.detail-popup-title {
  font-size: 32rpx;
  line-height: 1.5;
}

.detail-popup-subtitle,
.detail-file-meta {
  display: block;
  color: #6a7d90;
  font-size: 24rpx;
  line-height: 1.8;
}

.detail-popup-subtitle {
  margin-top: 8rpx;
}

.detail-popup-content {
  flex: 1;
  min-height: 0;
  margin-top: 20rpx;
}

.detail-card,
.detail-state-card {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 16rpx 36rpx rgba(24, 62, 107, 0.08);
}

.detail-card:first-child,
.detail-state-card:first-child {
  margin-top: 0;
}

.detail-section-head {
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.detail-section-title {
  font-size: 30rpx;
}

.detail-desc {
  margin-top: 18rpx;
}

.detail-image-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.detail-image {
  width: 100%;
  height: 180rpx;
  border-radius: 18rpx;
  background: #eef3f8;
}

.detail-file-list {
  margin-top: 18rpx;
}

.detail-file-row {
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 14rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 1rpx solid rgba(223, 229, 237, 0.9);
}

.detail-file-name {
  display: block;
  color: #16324c;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.6;
  word-break: break-all;
}

.detail-file-link {
  flex-shrink: 0;
  color: #1f7ae0;
  font-size: 24rpx;
  font-weight: 600;
}

.detail-empty-panel {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: #f6f9fc;
}

.detail-empty-panel-top {
  margin-top: 16rpx;
}

.detail-feedback-panel {
  margin-top: 16rpx;
}

.detail-subsection {
  margin-top: 24rpx;
}

.detail-subtitle {
  font-size: 26rpx;
}

.detail-bottom-space {
  height: 32rpx;
}
