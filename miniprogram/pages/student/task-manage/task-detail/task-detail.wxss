/* 学生任务详情 - 页面特有样式 */

.section-card:nth-last-child(2) {
  margin-bottom: 50rpx;
}

.hero-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-title-group {
  flex: 1;
  min-width: 0;
}

.hero-title {
  font-size: 38rpx;
  line-height: 1.4;
  word-break: break-all;
  color: #16324c;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #6a7d90;
  font-size: 24rpx;
  line-height: 1.8;
}

.hero-desc {
  margin-top: 22rpx;
  color: #35536c;
  font-size: 26rpx;
  font-weight: 500;
  line-height: 1.8;
}

.section-subtitle {
  max-width: 280rpx;
  color: #7a8797;
  font-size: 22rpx;
  line-height: 1.7;
  text-align: right;
}

.section-tip {
  display: block;
  margin-top: 14rpx;
  color: #7a8797;
  font-size: 22rpx;
  line-height: 1.7;
}

.detail-desc {
  display: block;
  color: #35536c;
  font-size: 26rpx;
  font-weight: 500;
  line-height: 1.8;
}

.primary-action-btn,
.ghost-action-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  margin: 0;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.primary-action-btn::after,
.ghost-action-btn::after {
  border: none;
}

.primary-action-btn {
  color: #ffffff;
  background: linear-gradient(135deg, #1f7ae0 0%, #4a8ff5 100%);
}

.ghost-action-btn {
  color: #1f4f78;
  background: #e7f1fb;
}

.submission-list {
  margin-top: 18rpx;
}

.submission-card {
  margin-top: 16rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: #f8fafc;
  border: 1rpx solid rgba(103, 126, 167, 0.08);
}

.submission-card:first-child {
  margin-top: 0;
}

.submission-title,
.feedback-label {
  display: block;
  color: #16324c;
  font-size: 26rpx;
  font-weight: 600;
}

.submission-time,
.submission-meta,
.feedback-text,
.link-text {
  display: block;
  color: #6a7d90;
  font-size: 22rpx;
  line-height: 1.7;
}

.submission-status {
  display: inline-flex;
  align-items: center;
  align-self: flex-start;
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.submission-desc {
  display: block;
  margin-top: 16rpx;
  color: #35536c;
  font-size: 24rpx;
  line-height: 1.8;
}

.submission-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 18rpx;
  margin-top: 16rpx;
}

.feedback-panel {
  margin-top: 16rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(31, 122, 224, 0.08);
}

.link-text {
  display: inline-flex;
  margin-top: 16rpx;
  color: #1f7ae0;
  font-weight: 600;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.plain-tag {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #1f4f78;
  background: rgba(31, 122, 224, 0.1);
}

.plain-tag-light {
  color: #51697f;
  background: #eef3f8;
}

.ghost-copy-btn {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  margin: 0;
  border-radius: 999rpx;
  color: #1f4f78;
  background: #e7f1fb;
  font-size: 24rpx;
  font-weight: 600;
}

.ghost-copy-btn::after {
  border: none;
}

.detail-panel {
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(31, 122, 224, 0.08);
}

.detail-panel-soft {
  background: #f6f9fc;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 18rpx;
}

.task-image {
  width: 100%;
  height: 240rpx;
  border-radius: 22rpx;
  background: #eef3f8;
}

.file-list {
  margin-top: 18rpx;
}

.file-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 16rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 2rpx solid #e5e7eb;
}

.file-main {
  flex: 1;
  min-width: 0;
}

.file-name {
  display: block;
  color: #111827;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.6;
  word-break: break-all;
}

.file-meta {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.7;
}

.file-preview-text {
  flex-shrink: 0;
  color: #1f7ae0;
  font-size: 24rpx;
  font-weight: 600;
}

.footer-placeholder {
  height: calc(32rpx + env(safe-area-inset-bottom));
}
