/* 学生任务管理 - 页面特有样式 */

.filter-card,
.summary-card,
.tab-card,
.task-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(103, 126, 167, 0.08);
  box-shadow: 0 20rpx 50rpx rgba(24, 62, 107, 0.08);
}

.task-card:nth-last-child(1) {
  margin-bottom: 24rpx;
}

.hero-card {
  background: linear-gradient(135deg, #ffffff 0%, #eef6ff 52%, #f5fbff 100%);
}

.hero-top,
.filter-header,
.task-top,
.tab-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.task-title {
  flex: 1;
  min-width: 0;
}

.task-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.task-title,
.tab-title {
  display: block;
  color: #16324c;
  font-size: 30rpx;
  font-weight: 700;
}

.hero-desc,
.tab-desc,
.time-text {
  display: block;
  color: #6a7d90;
  font-size: 24rpx;
  line-height: 1.8;
}

.hero-tag,
.scope-tag,
.plain-tag {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.hero-tag {
  color: #1f4f78;
  background: rgba(31, 122, 224, 0.1);
}

.filter-group + .filter-group {
  margin-top: 22rpx;
}

.filter-title {
  color: #16324c;
  font-size: 30rpx;
  font-weight: 700;
}

.filter-desc {
  color: #6a7d90;
  font-size: 22rpx;
  line-height: 1.7;
  text-align: right;
}

.filter-label {
  display: block;
  color: #7b8798;
  font-size: 22rpx;
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 16rpx;
}

.filter-pill {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #f4f7fb;
  color: #5f7387;
  font-size: 24rpx;
}

.filter-pill-active {
  background: rgba(31, 122, 224, 0.12);
  color: #1f7ae0;
  font-weight: 600;
}

.meta-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 24rpx;
}

.meta-item {
  width: calc(50% - 10rpx);
  margin-bottom: 18rpx;
  box-sizing: border-box;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f6f9fc;
}

.meta-item:nth-last-child(-n + 2) {
  margin-bottom: 0;
}

.meta-label {
  display: block;
  color: #7b8798;
  font-size: 22rpx;
}

.meta-value {
  display: block;
  margin-top: 10rpx;
  color: #1f3349;
  font-size: 30rpx;
  line-height: 1.5;
  word-break: break-all;
}

.tab-desc {
  max-width: 280rpx;
  text-align: right;
  font-size: 22rpx;
}

.task-project {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #0f6b66;
  background: rgba(15, 107, 102, 0.1);
}

.scope-tag {
  color: #51697f;
  background: #eef3f8;
}

.scope-tag-active {
  color: #0c7f58;
  background: rgba(12, 127, 88, 0.1);
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.plain-tag {
  color: #1f4f78;
  background: rgba(31, 122, 224, 0.1);
}

.plain-tag-light {
  color: #51697f;
  background: #eef3f8;
}

.task-desc {
  display: block;
  margin-top: 22rpx;
  padding: 22rpx 24rpx;
  border-left: 6rpx solid #1f7ae0;
  border-radius: 20rpx;
  background: rgba(31, 122, 224, 0.08);
  color: #35536c;
  font-size: 24rpx;
  line-height: 1.8;
}

.task-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 24rpx;
}

.detail-link {
  flex-shrink: 0;
  color: #1f7ae0;
  font-size: 24rpx;
  font-weight: 600;
}

.bottom-tab-bar .tab-card {
  margin-bottom: 0;
  box-shadow: 0 16rpx 40rpx rgba(24, 62, 107, 0.12);
}

.loading-more,
.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
}

.loading-more-text,
.no-more-text {
  color: #97a3b7;
  font-size: 24rpx;
}

/* 统计骨架加载动画 */
.skeleton-block {
  width: 80rpx;
  height: 34rpx;
  margin-top: 10rpx;
  border-radius: 8rpx;
  background: #e8edf2;
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

@keyframes skeleton-pulse {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 0.8; }
}
