/* 学生首页 - 页面特有样式 */
.content {
  padding: 0rpx 24rpx calc(100rpx + env(safe-area-inset-bottom));
}

.quick-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 18rpx 0;
  margin-top: 24rpx;
}

.quick-card {
  width: calc(50% - 10rpx);
  box-sizing: border-box;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f7f9fc;
}

.quick-mark {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: rgba(31, 122, 224, 0.12);
  color: #1f7ae0;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 64rpx;
  text-align: center;
}

.quick-title {
  display: block;
  margin-top: 18rpx;
  color: #17314a;
  font-size: 28rpx;
  font-weight: 700;
}

.quick-desc {
  margin-top: 10rpx;
  color: #1f3349;
  font-size: 26rpx;
  line-height: 1.5;
}

.hero-actions {
  margin-top: 24rpx;
}

.primary-btn,
.ghost-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 24rpx;
  margin: 0;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: ;
}

.block-btn {
  width: 100%;
  margin-top: 24rpx;
}

.featured-task-panel {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(31, 122, 224, 0.16);
  background: linear-gradient(180deg, #f8fbff 0%, #eef5ff 100%);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.72);
}

.featured-task-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.featured-task-link {
  flex-shrink: 0;
  color: #1f7ae0;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.8;
}

.focus-title {
  display: block;
  color: #17314a;
  font-size: 30rpx;
  font-weight: 700;
}

.focus-desc {
  color: #6d7d90;
  margin-top: 12rpx;
  font-size: 26rpx;
}

.weekly-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.weekly-tag {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #1f7ae0;
  background: rgba(31, 122, 224, 0.12);
  font-size: 22rpx;
  line-height: 1.2;
}

.weekly-tag-light {
  color: #6d7d90;
  background: #eef3f8;
}

.weekly-summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 22rpx;
}

.weekly-summary-item {
  flex: 1;
  min-width: 0;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: #f6f9fc;
}

.weekly-summary-label {
  display: block;
  color: #65788c;
  font-size: 24rpx;
  line-height: 1.8;
}

.weekly-summary-value {
  display: block;
  margin-top: 8rpx;
  color: #17314a;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.5;
}

.focus-progress {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 22rpx;
}

.progress-track {
  flex: 1;
  height: 14rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(31, 122, 224, 0.12);
}

.progress-bar {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #1f7ae0 0%, #2f8f57 100%);
}

.progress-text {
  flex-shrink: 0;
  color: #1f3349;
  font-size: 22rpx;
  font-weight: 600;
}

.focus-meta {
  margin-top: 18rpx;
}

.focus-meta-item {
  display: block;
  color: #65788c;
  font-size: 24rpx;
  line-height: 1.8;
}

.tip-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 20rpx;
}

.tip-item {
  display: block;
  color: #65788c;
  font-size: 24rpx;
  line-height: 1.8;
}

.notice-close {
  color: #7a8797;
  font-size: 22rpx;
}
