/* 教师首页 - 页面特有样式 */

.navbar-wrapper {
  background: rgba(255, 255, 255, 0.96);
}

.hero-notice {
  display: block;
  margin-top: 12rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  color: #8a6400;
  font-size: 22rpx;
  line-height: 1.6;
  background: rgba(248, 182, 54, 0.16);
}

.quick-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 18rpx 0;
  margin-top: 24rpx;
}

.quick-card {
  width: calc(50% - 10rpx);
  box-sizing: border-box;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f7f9fc;
}

.quick-mark {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: rgba(31, 122, 224, 0.12);
  color: #1f7ae0;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 64rpx;
  text-align: center;
}

.quick-title {
  display: block;
  margin-top: 18rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.quick-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
}

.stats-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 18rpx 0;
  margin-top: 24rpx;
}

.stats-item {
  width: calc(33.333% - 12rpx);
  box-sizing: border-box;
  padding: 22rpx 18rpx;
  border-radius: 22rpx;
  background: #f7f9fc;
  text-align: center;
}

.stats-label {
  display: block;
  color: #7b8798;
  font-size: 22rpx;
}

.stats-value {
  display: block;
  margin-top: 10rpx;
  color: #1f3349;
  font-size: 30rpx;
  font-weight: 700;
}

.activity-list {
  margin-top: 18rpx;
}

.activity-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(223, 229, 237, 0.9);
}

.activity-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.activity-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #1f7ae0;
  margin-top: 12rpx;
  flex-shrink: 0;
}

.activity-copy {
  flex: 1;
  min-width: 0;
}

.activity-text {
  display: block;
  color: #17314a;
  font-size: 28rpx;
  font-weight: 700;
}

.activity-time {
  display: block;
  margin-top: 8rpx;
  color: #65788c;
  font-size: 24rpx;
  line-height: 1.8;
}

.empty-activity {
  display: block;
  margin-top: 18rpx;
  color: #7b8798;
  font-size: 24rpx;
  line-height: 1.8;
}
