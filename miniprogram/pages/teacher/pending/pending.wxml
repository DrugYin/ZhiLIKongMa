<!--pages/teacher/pending/pending.wxml-->
<view class="container">
  <view class="header">
    <view class="navbar-wrapper">
      <custom-navbar placeholder="{{true}}" title="智力控码" />
    </view>
  </view>
  <scroll-view class="content" scroll-y enhanced enable-back-to-top scroll-top="{{scrollTop}}" bindscrolltolower="onScrollToLower">
    <view id="back-top-sentinel" style="height:1rpx;"></view>
    <view wx:if="{{loading}}" class="section-card">
      <text class="empty-title">审核记录加载中</text>
      <text class="empty-desc">正在同步学生提交、入班申请和当前审核状态。</text>
    </view>

    <block wx:else>
    <view class="hero-card">
      <text class="hero-eyebrow">审核中心</text>
      <text class="hero-title">先处理任务提交和入班申请，再回到任务管理页继续维护。</text>
      <text class="hero-desc">这里会集中展示当前教师名下的任务审核记录和班级加入申请，处理结果会即时回写到学生侧状态。</text>

      <view class="summary-grid">
        <view class="summary-item">
          <text class="summary-label">全部记录</text>
          <block wx:if="{{statsLoading}}"><view class="skeleton-block"></view></block>
          <text wx:else class="summary-value">{{stats.total}}</text>
        </view>
        <view class="summary-item">
          <text class="summary-label">待审提交</text>
          <block wx:if="{{statsLoading}}"><view class="skeleton-block"></view></block>
          <text wx:else class="summary-value">{{stats.taskPending}}</text>
        </view>
        <view class="summary-item">
          <text class="summary-label">待审申请</text>
          <block wx:if="{{statsLoading}}"><view class="skeleton-block"></view></block>
          <text wx:else class="summary-value">{{stats.joinPending}}</text>
        </view>
        <view class="summary-item">
          <text class="summary-label">全部待审核</text>
          <block wx:if="{{statsLoading}}"><view class="skeleton-block"></view></block>
          <text wx:else class="summary-value">{{stats.pending}}</text>
        </view>
        <view class="summary-item">
          <text class="summary-label">已通过</text>
          <block wx:if="{{statsLoading}}"><view class="skeleton-block"></view></block>
          <text wx:else class="summary-value">{{stats.approved}}</text>
        </view>
        <view class="summary-item">
          <text class="summary-label">已驳回</text>
          <block wx:if="{{statsLoading}}"><view class="skeleton-block"></view></block>
          <text wx:else class="summary-value">{{stats.rejected}}</text>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-header">
        <text class="section-title">筛选条件</text>
        <text class="section-extra">快速定位</text>
      </view>

      <view class="filter-group">
        <text class="filter-label">审核类型</text>
        <view class="filter-row">
          <view
            wx:for="{{typeOptions}}"
            wx:key="value"
            class="filter-pill {{typeFilter === item.value ? 'filter-pill-active' : ''}}"
            data-value="{{item.value}}"
            bindtap="onTypeFilterChange"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="filter-group">
        <text class="filter-label">审核状态</text>
        <view class="filter-row">
          <view
            wx:for="{{statusOptions}}"
            wx:key="value"
            class="filter-pill {{statusFilter === item.value ? 'filter-pill-active' : ''}}"
            data-value="{{item.value}}"
            bindtap="onStatusFilterChange"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="filter-group">
        <text class="filter-label">所属班级</text>
        <view class="filter-row">
          <view
            wx:for="{{classOptions}}"
            wx:key="value"
            class="filter-pill {{classFilter === item.value ? 'filter-pill-active' : ''}}"
            data-value="{{item.value}}"
            bindtap="onClassFilterChange"
          >
            {{item.label}}
          </view>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-header">
        <text class="section-title">审核列表</text>
        <text class="section-extra">{{currentFilterTotal}} 条</text>
      </view>

      <view wx:if="{{displayRecords.length}}" class="review-list">
        <block wx:for="{{displayRecords}}" wx:key="recordKey">
          <view wx:if="{{item.recordType === 'submission'}}" class="review-card" data-id="{{item.id}}" bindtap="openRecordPopup">
            <view class="review-top">
              <view class="review-copy">
                <text class="review-name">{{item.studentName}}</text>
                <text class="review-meta">{{item.className}} · {{item.projectText}}</text>
              </view>
              <view class="review-tag-group">
                <text class="type-tag">{{item.typeText}}</text>
                <text class="status-tag status-{{item.status}}">{{item.statusText}}</text>
              </view>
            </view>

            <text class="review-task-title">{{item.taskTitle}}</text>
            <text class="review-desc">{{item.summary}}</text>

            <view wx:if="{{item.feedbackText && item.status !== 'pending'}}" class="review-feedback">
              <text class="review-feedback-label">处理意见</text>
              <text class="review-feedback-text">{{item.feedbackText}}</text>
            </view>

            <view class="meta-grid">
              <view class="meta-item">
                <text class="meta-label">提交时间</text>
                <text class="meta-value">{{item.submittedAt}}</text>
              </view>
              <view class="meta-item">
                <text class="meta-label">材料概览</text>
                <text class="meta-value">{{item.attachmentText}}</text>
              </view>
              <view class="meta-item">
                <text class="meta-label">审核评分</text>
                <text class="meta-value">{{item.scoreText}}</text>
              </view>
              <view class="meta-item">
                <text class="meta-label">积分结果</text>
                <text class="meta-value">{{item.pointsText}} · {{item.overtimeText}}</text>
              </view>
            </view>

            <text class="review-link">{{item.status === 'pending' ? '点击查看详情并审核' : '点击查看完整审核信息'}}</text>
          </view>

          <view wx:else class="review-card application-review-card">
            <view class="review-top">
              <view class="review-copy">
                <text class="review-name">{{item.studentName}}</text>
                <text class="review-meta">{{item.className}} · {{item.projectText}}</text>
              </view>
              <view class="review-tag-group">
                <text class="type-tag type-tag-application">{{item.typeText}}</text>
                <text class="status-tag status-{{item.status}}">{{item.statusText}}</text>
              </view>
            </view>

            <text class="review-task-title">{{item.taskTitle}}</text>
            <text class="review-desc">{{item.summary}}</text>

            <view class="application-info-grid">
              <view class="meta-item">
                <text class="meta-label">年级信息</text>
                <text class="meta-value">{{item.gradeText}}</text>
              </view>
              <view class="meta-item">
                <text class="meta-label">联系电话</text>
                <text class="meta-value">{{item.phoneText}}</text>
              </view>
            </view>

            <view class="review-feedback application-reason-box">
              <text class="review-feedback-label">申请理由</text>
              <text class="review-feedback-text">{{item.descriptionText}}</text>
            </view>

            <view wx:if="{{item.feedbackText && item.status !== 'pending'}}" class="review-feedback application-review-feedback">
              <text class="review-feedback-label">处理意见</text>
              <text class="review-feedback-text">{{item.feedbackText}}</text>
            </view>

            <view class="meta-grid">
              <view class="meta-item">
                <text class="meta-label">提交时间</text>
                <text class="meta-value">{{item.submittedAt}}</text>
              </view>
              <view class="meta-item">
                <text class="meta-label">{{item.status === 'pending' ? '相对时间' : '处理时间'}}</text>
                <text class="meta-value">{{item.status === 'pending' ? item.relativeTimeText : item.reviewedAt}}</text>
              </view>
            </view>

            <view wx:if="{{item.status === 'pending'}}" class="action-row application-action-row">
              <button
                class="danger-btn"
                data-application-id="{{item.rawId}}"
                data-action="reject"
                data-student-name="{{item.studentName}}"
                catchtap="onReviewClassApplication"
                disabled="{{reviewingApplicationId}}"
                loading="{{reviewingApplicationId === item.rawId && reviewAction === 'reject'}}"
              >
                拒绝
              </button>
              <button
                class="primary-btn"
                data-application-id="{{item.rawId}}"
                data-action="approve"
                data-student-name="{{item.studentName}}"
                catchtap="onReviewClassApplication"
                disabled="{{reviewingApplicationId}}"
                loading="{{reviewingApplicationId === item.rawId && reviewAction === 'approve'}}"
              >
                通过
              </button>
            </view>

            <text wx:else class="review-link">{{item.status === 'approved' ? '该申请已通过' : '该申请已拒绝'}}</text>
          </view>
        </block>
      </view>

      <view wx:else class="empty-card">
        <text class="empty-title">当前筛选下没有记录</text>
        <text class="empty-desc">可以切换审核类型、状态或班级条件，继续查看其它待办。</text>
      </view>

      <view wx:if="{{loadingMore}}" class="loading-more">
        <text class="loading-more-text">加载中...</text>
      </view>
      <view wx:elif="{{!hasMore && records.length > 0}}" class="no-more">
        <text class="no-more-text">没有更多记录了</text>
      </view>
    </view>

    <view class="section-card">
      <view class="section-header">
        <text class="section-title">后续建议</text>
        <text class="section-extra">继续处理</text>
      </view>
      <view class="action-row action-row-secondary">
        <button class="ghost-btn" bindtap="goToTaskManage">前往任务管理</button>
      </view>
    </view>

    <view class="footer-placeholder"></view>
    </block>
  </scroll-view>

  <back-top visible="{{backTopVisible}}" bind:toTop="onBackToTop" />

  <t-popup
    visible="{{popupVisible}}"
    placement="bottom"
    usingCustomNavbar="{{true}}"
    close-on-overlay-click="{{true}}"
    prevent-scroll-through="{{true}}"
    bind:visible-change="onPopupVisibleChange"
  >
    <view class="popup-shell">
      <view class="popup-header">
        <view class="popup-header-copy">
          <text class="popup-title">{{popupRecord ? popupRecord.taskTitle : '提交详情'}}</text>
          <text class="popup-subtitle">{{popupRecord ? popupRecord.studentName + ' · ' + popupRecord.className : '正在加载'}}</text>
        </view>
        <text wx:if="{{popupRecord}}" class="status-tag status-{{popupRecord.status}}">{{popupRecord.statusText}}</text>
      </view>

      <scroll-view class="popup-content" scroll-y enhanced>
        <view wx:if="{{popupLoading}}" class="popup-state-card">
          <text class="empty-title">详情加载中</text>
          <text class="empty-desc">正在同步提交说明、图片和附件。</text>
        </view>

        <block wx:elif="{{popupRecord}}">
          <view class="popup-card">
            <view class="popup-grid">
              <view class="popup-item">
                <text class="popup-label">提交时间</text>
                <text class="popup-value">{{popupRecord.submittedAt}}</text>
              </view>
              <view class="popup-item">
                <text class="popup-label">审核时间</text>
                <text class="popup-value">{{popupRecord.reviewedAt}}</text>
              </view>
              <view class="popup-item">
                <text class="popup-label">材料概览</text>
                <text class="popup-value">{{popupRecord.attachmentText}}</text>
              </view>
              <view class="popup-item">
                <text class="popup-label">当前积分</text>
                <text class="popup-value">{{popupRecord.pointsText}} · {{popupRecord.overtimeText}}</text>
              </view>
            </view>
          </view>

          <view class="popup-card">
            <text class="section-title">提交说明</text>
            <view class="popup-panel">
              <text class="review-desc">{{popupRecord.descriptionText}}</text>
            </view>
          </view>

          <view class="popup-card">
            <view class="section-header">
              <text class="section-title">提交图片</text>
              <text class="section-extra">{{popupRecord.imageCount}} 张</text>
            </view>

            <view wx:if="{{popupRecordDetail.imageList.length}}" class="popup-image-grid">
              <image
                wx:for="{{popupRecordDetail.imageList}}"
                wx:key="fileId"
                class="popup-image"
                src="{{item.url}}"
                mode="aspectFill"
                data-index="{{index}}"
                bindtap="onPreviewPopupImage"
              />
            </view>

            <view wx:else class="popup-panel popup-panel-soft">
              <text class="empty-desc">本次提交没有上传图片。</text>
            </view>
          </view>

          <view class="popup-card">
            <view class="section-header">
              <text class="section-title">附件文件</text>
              <text class="section-extra">{{popupRecord.fileCount}} 个</text>
            </view>

            <view wx:if="{{popupRecordDetail.attachmentFiles.length}}" class="popup-file-list">
              <view
                wx:for="{{popupRecordDetail.attachmentFiles}}"
                wx:key="file_id"
                class="popup-file-row"
                data-index="{{index}}"
                bindtap="onPreviewPopupFile"
              >
                <view class="popup-file-main">
                  <text class="popup-file-name">{{item.file_name || item.name}}</text>
                  <text class="popup-file-meta">点击预览 · {{item.sizeText || '大小待补充'}}</text>
                </view>
                <text class="popup-file-link">预览</text>
              </view>
            </view>

            <view wx:else class="popup-panel popup-panel-soft">
              <text class="empty-desc">本次提交没有上传附件。</text>
            </view>
          </view>

          <view wx:if="{{popupRecord.feedbackText && popupRecord.status !== 'pending'}}" class="popup-card">
            <text class="section-title">已处理意见</text>
            <view class="popup-panel">
              <text class="review-desc">{{popupRecord.feedbackText}}</text>
            </view>
          </view>

          <view wx:if="{{popupRecord.status !== 'pending'}}" class="popup-card">
            <view class="section-header">
              <text class="section-title">教师补充图片</text>
              <text class="section-extra">{{popupRecord.feedbackImageCount}} 张</text>
            </view>

            <view wx:if="{{popupRecordDetail.feedbackImageList.length}}" class="popup-image-grid">
              <image
                wx:for="{{popupRecordDetail.feedbackImageList}}"
                wx:key="fileId"
                class="popup-image"
                src="{{item.url}}"
                mode="aspectFill"
                data-index="{{index}}"
                bindtap="onPreviewFeedbackImage"
              />
            </view>

            <view wx:else class="popup-panel popup-panel-soft">
              <text class="empty-desc">老师没有补充图片材料。</text>
            </view>
          </view>

          <view wx:if="{{popupRecord.status !== 'pending'}}" class="popup-card">
            <view class="section-header">
              <text class="section-title">教师补充附件</text>
              <text class="section-extra">{{popupRecord.feedbackFileCount}} 个</text>
            </view>

            <view wx:if="{{popupRecordDetail.feedbackAttachmentFiles.length}}" class="popup-file-list">
              <view
                wx:for="{{popupRecordDetail.feedbackAttachmentFiles}}"
                wx:key="file_id"
                class="popup-file-row"
                data-index="{{index}}"
                bindtap="onPreviewFeedbackFile"
              >
                <view class="popup-file-main">
                  <text class="popup-file-name">{{item.file_name || item.name}}</text>
                  <text class="popup-file-meta">点击预览 · {{item.sizeText || '大小待补充'}}</text>
                </view>
                <text class="popup-file-link">预览</text>
              </view>
            </view>

            <view wx:else class="popup-panel popup-panel-soft">
              <text class="empty-desc">老师没有补充附件材料。</text>
            </view>
          </view>

          <view wx:if="{{popupRecord.status === 'pending'}}" class="popup-card">
            <text class="section-title">审核操作</text>

            <view class="review-field">
              <text class="review-field-label">评分</text>
              <view class="review-input-wrap">
                <t-input
                  type="digit"
                  placeholder="可选，填写评分"
                  value="{{reviewForm.score}}"
                  clearable
                  data-field="score"
                  bind:change="onReviewFieldChange"
                />
              </view>
            </view>

            <view class="review-field">
              <text class="review-field-label">发放积分</text>
              <view class="review-input-wrap">
                <t-input
                  type="number"
                  placeholder="默认使用任务积分"
                  value="{{reviewForm.points}}"
                  tips="默认按任务积分发放：{{popupRecord.taskPoints}} 分。若驳回，本次不会发放积分。"
                  data-field="points"
                  bind:change="onReviewFieldChange"
                />
              </view>
            </view>

            <view class="review-field">
              <text class="review-field-label">处理意见</text>
              <view class="review-textarea-wrap">
                <t-textarea
                  value="{{reviewForm.feedback}}"
                  maxlength="{{300}}"
                  placeholder="可填写审核意见；驳回时建议说明需要补充的内容"
                  indicator
                  autosize
                  bordered
                  fixed
                  data-field="feedback"
                  bind:change="onReviewFieldChange"
                />
              </view>
            </view>

            <view class="review-field">
              <view class="section-header section-header-compact">
                <text class="review-field-label">补充图片</text>
                <text class="section-extra">{{reviewImageFiles.length}} / {{reviewImageMax}}</text>
              </view>
              <view class="review-upload-wrap">
                <t-upload
                  files="{{reviewImageFiles}}"
                  max="{{reviewImageMax}}"
                  media-type="{{imageMediaType}}"
                  config="{{imageUploadConfig}}"
                  size-limit="{{imageSizeLimit}}"
                  grid-config="{{imageGridConfig}}"
                  draggable
                  bind:add="onReviewImageAdd"
                  bind:remove="onReviewImageRemove"
                />
              </view>
            </view>

            <view class="review-field">
              <view class="section-header section-header-compact">
                <text class="review-field-label">补充附件</text>
                <text class="section-extra">{{reviewFileFiles.length}} / {{reviewFileMax}}</text>
              </view>
              <view class="review-file-toolbar">
                <button
                  class="ghost-btn file-select-btn"
                  bindtap="onSelectReviewFiles"
                  disabled="{{reviewFileFiles.length >= reviewFileMax}}"
                >
                  添加反馈附件
                </button>
              </view>

              <view wx:if="{{reviewFileFiles.length}}" class="popup-file-list review-file-list">
                <view
                  wx:for="{{reviewFileFiles}}"
                  wx:key="_uploadId"
                  class="popup-file-row"
                  data-index="{{index}}"
                  bindtap="onPreviewReviewUploadFile"
                >
                  <view class="popup-file-main">
                    <text class="popup-file-name">{{item.file_name || item.name}}</text>
                    <text class="popup-file-meta">
                      {{item.status === 'loading' ? '上传中' : item.status === 'failed' ? '上传失败' : '点击预览'}} · {{item.sizeText || '大小待补充'}}
                    </text>
                  </view>
                  <text class="popup-file-link popup-file-delete" data-index="{{index}}" catchtap="onDeleteReviewFile">移除</text>
                </view>
              </view>

              <view wx:else class="popup-panel popup-panel-soft review-empty-panel">
                <text class="empty-desc">可选上传批注截图、示例答案或补充说明文档。</text>
              </view>

              <text class="review-field-tip">支持格式：{{fileAcceptText}}</text>
            </view>

            <view class="action-row popup-action-row">
              <button class="danger-btn" disabled="{{processingId === popupRecord.id}}" catchtap="handleReject">驳回</button>
              <button class="primary-btn" disabled="{{processingId === popupRecord.id}}" catchtap="handleApprove">通过</button>
            </view>
          </view>

          <view class="popup-bottom-space"></view>
        </block>
      </scroll-view>
    </view>
  </t-popup>
</view>
