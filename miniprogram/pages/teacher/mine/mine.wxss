/* 教师我的页 - 页面特有样式 */

.navbar-wrapper {
  background: rgba(255, 255, 255, 0.96);
}

.content {
  padding: 0rpx 24rpx calc(100rpx + env(safe-area-inset-bottom));
}

.profile-card {
  margin-top: 12rpx;
  background: linear-gradient(135deg, #ffffff 0%, #eef6ff 54%, #f8fbff 100%);
  padding: 28rpx;
  border-radius: 28rpx;
}

.profile-top {
  align-items: flex-start;
}

.profile-copy {
  flex: 1;
  min-width: 0;
}

.profile-eyebrow {
  display: block;
  color: #1f7ae0;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.profile-name {
  display: block;
  margin-top: 12rpx;
  font-size: 38rpx;
  line-height: 1.4;
  color: #17314a;
  font-weight: 700;
}

.profile-meta {
  display: block;
  margin-top: 12rpx;
  color: #65788c;
  font-size: 24rpx;
  line-height: 1.8;
}

.action-list {
  margin-top: 18rpx;
}

.action-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(223, 229, 237, 0.9);
}

.action-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.action-copy {
  flex: 1;
  min-width: 0;
}

.action-title {
  display: block;
  color: #17314a;
  font-weight: 700;
  font-size: 28rpx;
}

.action-desc {
  display: block;
  margin-top: 10rpx;
  color: #65788c;
  font-size: 24rpx;
  line-height: 1.8;
}

.action-arrow {
  flex-shrink: 0;
  color: #7a8797;
  font-size: 34rpx;
  line-height: 1;
}

.action-item-danger {
  border-bottom: none;
}

.action-title-danger,
.action-arrow-danger {
  color: #d84a55;
}
