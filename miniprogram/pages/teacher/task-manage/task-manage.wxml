<view class="container">
  <view class="header">
    <view class="navbar-wrapper">
      <custom-navbar placeholder="{{true}}" title="任务管理" />
    </view>
  </view>

  <scroll-view class="content" scroll-y enhanced bounces="{{false}}" show-scrollbar="{{false}}" scroll-top="{{scrollTop}}" bindscrolltolower="onScrollToLower">
    <view id="back-top-sentinel" style="height:1rpx;"></view>
    <view wx:if="{{loading}}" class="state-card">
      <text class="state-title">任务列表加载中</text>
      <text class="state-desc">正在同步教师端任务数据，请稍候。</text>
    </view>

    <block wx:elif="{{tasks.length}}">
      <view class="summary-card">
        <view class="summary-header">
          <text class="summary-title">任务概览</text>
          <text class="summary-desc">支持按项目、类型、范围和状态快速筛选</text>
        </view>
        <view class="summary-grid">
          <view class="summary-item">
            <text class="summary-label">任务总数</text>
            <text class="summary-value">{{stats.total}}</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">已发布</text>
            <text class="summary-value">{{stats.published}}</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">公开任务</text>
            <text class="summary-value">{{stats.publicCount}}</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">班级任务</text>
            <text class="summary-value">{{stats.classCount}}</text>
          </view>
        </view>
      </view>
      
      <view class="filter-card">
        <view class="summary-header">
          <text class="summary-title">筛选条件</text>
          <text class="summary-desc">按项目、类型、范围、状态和排序快速定位任务</text>
        </view>

        <view class="filter-group">
          <text class="filter-label">所属项目</text>
          <view class="filter-row">
            <view
              wx:for="{{projects.options}}"
              wx:key="value"
              class="filter-pill {{projects.value === item.value ? 'filter-pill-active' : ''}}"
              data-field="projects"
              data-value="{{item.value}}"
              bindtap="onFilterSelect"
            >
              {{item.label}}
            </view>
          </view>
        </view>

        <view class="filter-group">
          <text class="filter-label">任务类型</text>
          <view class="filter-row">
            <view
              wx:for="{{taskTypes.options}}"
              wx:key="value"
              class="filter-pill {{taskTypes.value === item.value ? 'filter-pill-active' : ''}}"
              data-field="taskTypes"
              data-value="{{item.value}}"
              bindtap="onFilterSelect"
            >
              {{item.label}}
            </view>
          </view>
        </view>

        <view wx:if="{{taskTypes.value === 'class'}}" class="filter-group">
          <text class="filter-label">所属班级</text>
          <view class="filter-row">
            <view
              wx:for="{{classes.options}}"
              wx:key="value"
              class="filter-pill {{classes.value === item.value ? 'filter-pill-active' : ''}}"
              data-field="classes"
              data-value="{{item.value}}"
              bindtap="onFilterSelect"
            >
              {{item.label}}
            </view>
          </view>
        </view>

        <view class="filter-group">
          <text class="filter-label">可见范围</text>
          <view class="filter-row">
            <view
              wx:for="{{visibility.options}}"
              wx:key="value"
              class="filter-pill {{visibility.value === item.value ? 'filter-pill-active' : ''}}"
              data-field="visibility"
              data-value="{{item.value}}"
              bindtap="onFilterSelect"
            >
              {{item.label}}
            </view>
          </view>
        </view>

        <view class="filter-group">
          <text class="filter-label">任务状态</text>
          <view class="filter-row">
            <view
              wx:for="{{status.options}}"
              wx:key="value"
              class="filter-pill {{status.value === item.value ? 'filter-pill-active' : ''}}"
              data-field="status"
              data-value="{{item.value}}"
              bindtap="onFilterSelect"
            >
              {{item.label}}
            </view>
          </view>
        </view>

        <view class="filter-group">
          <text class="filter-label">排序方式</text>
          <view class="filter-row">
            <view
              wx:for="{{sorted.options}}"
              wx:key="value"
              class="filter-pill {{sorted.value === item.value ? 'filter-pill-active' : ''}}"
              data-field="sorted"
              data-value="{{item.value}}"
              bindtap="onFilterSelect"
            >
              {{item.label}}
            </view>
          </view>
        </view>
      </view>

      <block wx:if="{{displayTasks.length}}">
        <view
          wx:for="{{displayTasks}}"
          wx:key="_id"
          class="task-card"
          data-task-id="{{item._id}}"
          bindtap="goToTaskDetail"
        >
          <view class="card-top">
            <view class="card-title-group">
              <text class="task-title">{{item.titleText}}</text>
              <text class="task-project">{{item.projectText}}</text>
            </view>
            <text class="status-tag {{item.statusClass}}">{{item.statusText}}</text>
          </view>

          <view class="tag-row">
            <text class="plain-tag">{{item.taskTypeText}}</text>
            <text class="plain-tag plain-tag-light">{{item.visibilityText}}</text>
            <text class="plain-tag" style="{{item.difficultyStyle}}">{{item.difficultyText}}</text>
          </view>

          <view class="task-meta-grid">
            <view class="meta-item">
              <text class="meta-label">面向对象</text>
              <text class="meta-value">{{item.classText}}</text>
            </view>
            <view class="meta-item">
              <text class="meta-label">任务积分</text>
              <text class="meta-value">{{item.pointsText}}</text>
            </view>
            <view class="meta-item">
              <text class="meta-label">截止时间</text>
              <text class="meta-value">{{item.deadlineText}}</text>
            </view>
            <view class="meta-item">
              <text class="meta-label">附件情况</text>
              <text class="meta-value">{{item.imageCountText}} / {{item.fileCountText}}</text>
            </view>
          </view>

          <view class="task-desc">{{item.descriptionText}}</view>

          <view class="card-footer">
            <view class="time-group">
              <text class="time-text">发布时间：{{item.publishTimeText}}</text>
              <text class="time-text">更新时间：{{item.updateTimeText}}</text>
            </view>
            <view class="action-group">
              <button
                class="action-btn action-btn-secondary"
                data-task-id="{{item._id}}"
                catchtap="goToTaskDetail"
              >
                详情
              </button>
              <button
                class="action-btn action-btn-danger"
                data-task-id="{{item._id}}"
                data-task-title="{{item.titleText}}"
                catchtap="onDeleteTask"
              >
                删除
              </button>
            </view>
          </view>
        </view>
      </block>

      <view wx:else class="state-card empty-card">
        <text class="state-title">暂无匹配任务</text>
        <text class="state-desc">{{emptyText}}</text>
      </view>

      <view wx:if="{{loadingMore}}" class="loading-more">
        <text class="loading-more-text">加载中...</text>
      </view>
      <view wx:elif="{{!hasMore && tasks.length > 0}}" class="no-more">
        <text class="no-more-text">没有更多任务了</text>
      </view>
    </block>

    <view wx:else class="state-card empty-card">
      <text class="state-title">还没有任务</text>
      <text class="state-desc">{{emptyText}}</text>
    </view>

  </scroll-view>

  <back-top visible="{{backTopVisible}}" bind:to-top="onBackToTop" />
</view>

<t-fab
  y-bounds="{{[50, 100]}}"
  using-custom-navbar
  draggable
  icon="add"
  bind:click="goToAddTask"
/>
