/**
 * 智慧控码训练系统 - 全局样式
 */

/* 引入通用样式 */
@import './styles/common.wxss';

/* 全局页面背景 */
page {
  background-color: #f3f3f3;
}

/* 统计骨架加载动画（全局复用） */
.skeleton-block {
  width: 80rpx;
  height: 34rpx;
  margin-top: 10rpx;
  border-radius: 8rpx;
  background: #e8edf2;
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

@keyframes skeleton-pulse {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 0.8; }
}
