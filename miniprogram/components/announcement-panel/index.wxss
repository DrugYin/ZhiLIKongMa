.announcement-mask {
  position: fixed;
  inset: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(23, 49, 74, 0.36);
  box-sizing: border-box;
}

.announcement-dialog {
  width: 100%;
  max-height: 72vh;
  padding: 30rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(103, 126, 167, 0.1);
  box-shadow: 0 24rpx 70rpx rgba(24, 62, 107, 0.18);
  box-sizing: border-box;
}

.announcement-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.announcement-eyebrow {
  display: block;
  color: #1f7ae0;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.announcement-title {
  display: block;
  margin-top: 12rpx;
  color: #17314a;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.45;
}

.announcement-count {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #1f4f78;
  background: rgba(31, 122, 224, 0.1);
  font-size: 22rpx;
  font-weight: 600;
}

.announcement-content {
  max-height: 44vh;
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  color: #4b6075;
  background: #f7f9fc;
  border: 1rpx solid rgba(223, 229, 237, 0.9);
  font-size: 27rpx;
  line-height: 1.85;
  white-space: pre-wrap;
  box-sizing: border-box;
}

.announcement-content text {
  white-space: pre-wrap;
}

.announcement-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 28rpx;
}

.primary-btn,
.ghost-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 24rpx;
  margin: 0;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.primary-btn::after,
.ghost-btn::after {
  border: none;
}

.primary-btn {
  color: #ffffff;
  background: linear-gradient(135deg, #1f7ae0 0%, #4a8ff5 100%);
}

.ghost-btn {
  color: #1f4f78;
  background: #e7f1fb;
}
